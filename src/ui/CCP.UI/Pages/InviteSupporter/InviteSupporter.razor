@page "/InviteSupporters"
@layout CCPLayout
@inject IJSRuntime JS

<PageTitle>Supporter Management</PageTitle>

<EditForm Model="InviteSupporterModel" OnValidSubmit="@Submit">

    <!-- Top Header -->
    <div class="dash-greeting">
        <div>
            <h2 class="dash-greeting-title">Invite Supporter</h2>
            <p class="dash-greeting-sub">Invite Your Supporter.</p>
        </div>
        <span class="dash-date">@DateTime.Now.ToString("dddd, MMMM d")</span>
    </div>

    <!-- Main Grid: Invite form til venstre, Supporter liste til højre -->
    <div class="Supporter-grid">

        <!-- VENSTRE SIDE: Invite Form -->
        <div class="Supporter-invite-container">
            <div class="dash-card">
                <div class="dash-card-header">
                    <span class="dash-card-title">Invite New Supporter</span>
                </div>

                <div class="Supporter-invite-form">
                    <div class="form-group">
                        <label class="form-label">Select Customer</label>
                        <InputSelect @bind-Value="InviteSupporterModel.CustomerId"
                                     class="form-input">
                            <option value="">-- Select a customer to promote --</option>
                            @foreach (var customer in customers)
                            {
                                <option value="@customer.Id">@customer.Name - @customer.Email</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Welcome Message (Optional)</label>
                        <textarea class="form-textarea"
                                  @bind="InviteSupporterModel.WelcomeMessage"
                                  rows="4"
                                  placeholder="Write a welcome message to the new supporter..."></textarea>
                    </div>

                    <button class="btn-primary" type="submit">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" />
                        </svg>
                        Send Invitation
                    </button>
                </div>
            </div>
        </div>

        <!-- HØJRE SIDE: Supporter Liste -->
        <div class="Supporter-list-container">
            <div class="dash-card">
                <div class="dash-card-header">
                    <span class="dash-card-title">Existing Supporters (@supporters.Count)</span>
                </div>

                <div class="Supporter-list">
                    @if (supporters.Count == 0)
                    {
                        <div class="empty-state">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                                <circle cx="9" cy="7" r="4" />
                                <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                            </svg>
                            <p>No supporters yet</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var supporter in supporters)
                        {
                            <div class="supporter-item">
                                <div class="supporter-avatar" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%)">
                                    @GetInitials(supporter.Name)
                                </div>
                                <div class="supporter-info">
                                    <div class="supporter-name">@supporter.Name</div>
                                    <div class="supporter-email">@supporter.Email</div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

    </div>
</EditForm>

