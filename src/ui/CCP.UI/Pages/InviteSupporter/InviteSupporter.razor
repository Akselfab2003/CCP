@using CCP.Shared.ValueObjects
@using Microsoft.AspNetCore.Authorization
@inject IJSRuntime JS
@attribute [Authorize(Policy = "RequireInviteUsers")]

<EditForm Model="InviteSupporterModel" OnValidSubmit="@Submit" OnInvalidSubmit="@OnInvalidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Main Grid: Invite form til venstre, info til højre -->
    <div class="Supporter-grid">

        <!-- VENSTRE SIDE: Invite Form -->
        <div class="Supporter-invite-container">
            <div class="dash-card">
                <div class="dash-card-header">
                    <span class="dash-card-title">Invite New Supporter</span>
                </div>

                <div class="Supporter-invite-form">
                    <div class="form-group">
                        <label class="form-label">Supporter Email</label>
                        <InputText @bind-Value="InviteSupporterModel.Email"
                                   type="email"
                                   class="form-input"
                                   placeholder="supporter@example.com" />
                        <ValidationMessage For="@(() => InviteSupporterModel.Email)" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Welcome Message (Optional)</label>
                        <textarea class="form-textarea"
                                  @bind="InviteSupporterModel.WelcomeMessage"
                                  rows="4"
                                  placeholder="Write a welcome message to the new supporter..."></textarea>
                    </div>

                    <button class="btn-primary" type="submit" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner"></span>
                            <span>Sending...</span>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" />
                            </svg>
                            <span>Send Invitation</span>
                        }
                    </button>
                </div>
            </div>
        </div>

        <!-- HØJRE SIDE: Info -->
        <div class="Supporter-list-container">
            <div class="dash-card">
                <div class="dash-card-header">
                    <span class="dash-card-title">About Supporters</span>
                </div>
                <div class="info-content">
                    <p>Supporters can help manage tickets and provide customer support.</p>
                    <p>An invitation email will be sent with a link to create their account.</p>
                </div>
            </div>
        </div>

    </div>
</EditForm>

<!-- Toast Notifications -->
@if (successMessage != null)
{
    <div class="toast toast-success">
        @successMessage
        <button @onclick="@(() => successMessage = null)">×</button>
    </div>
}

@if (submitErrorMessage != null)
{
    <div class="toast toast-error">
        @submitErrorMessage
        <button @onclick="@(() => submitErrorMessage = null)">×</button>
    </div>
}



