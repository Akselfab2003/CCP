@page "/tenant-configuration"
@layout CCPLayout
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "CCP.Rolesorg.Admin")]
<div class="container">
    <div class="header">
        <h1 class="header-title">Email Configuration</h1>
        <p class="header-subtitle">Set up your email integration to automatically create tickets from incoming messages</p>
    </div>

    @if (EmailSaved)
    {
        <div class="success-message">
            <p>
                Please redirect your customers to use <strong>@Email</strong> for all support inquiries.
                New emails sent to this address will automatically create support tickets in your system.
            </p>
        </div>
    }

    <div class="email-form">
        <div class="form-group">
            <label for="email-input" class="form-label">Default Email Address</label>
            <div class="form-input-group">
                <input type="email"
                       id="email-input"
                       class="email-input"
                       placeholder="example@company.com"
                       @bind-value="Email"
                       aria-label="Enter default email" />
                <button class="btn btn-primary" @onclick="SaveEmailConfig" disabled="@IsSaving">
                    @if (IsSaving)
                    {
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save Email</span>
                    }
                </button>
            </div>
        </div>
    </div>
</div>


