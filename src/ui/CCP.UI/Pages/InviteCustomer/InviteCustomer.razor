@page "/InviteCustomers"
@layout CCPLayout
@using CCP.Shared.ValueObjects
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireManager")]


<PageTitle>Customer Management</PageTitle>

<EditForm Model="InviteCustomerModel" OnValidSubmit="@Submit" data-testid="invite-customer-form">

    <!-- Top Header -->
    <div class="dash-greeting">
        <div>
            <h2 class="dash-greeting-title">Invite Customer</h2>
            <p class="dash-greeting-sub">Invite Your customer to the CCP APP.</p>
        </div>
        <span class="dash-date">@DateTime.Now.ToString("dddd, MMMM d")</span>
    </div>

    <!-- Main Grid: Invite form til venstre, Customer liste til højre -->
    <div class="customer-grid">

        <!-- VENSTRE SIDE: Invite Form -->
        <div class="customer-invite-container">
            <div class="dash-card">
                <div class="dash-card-header">
                    <span class="dash-card-title">Invite New Customer</span>
                </div>

                <div class="customer-invite-form">
                    <div class="form-group">
                        <label class="form-label">Customer Email</label>
                        <InputText @bind-Value="InviteCustomerModel.Email"
                                   type="email"
                                   class="form-input"
                                   placeholder="customer@example.com" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Welcome Message</label>
                        <textarea class="form-textarea"
                                  rows="4"
                                  placeholder="Write a welcome message to the customer..."></textarea>
                    </div>

                    <button class="btn-primary" type="submit">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" />
                        </svg>
                        Send Invitation
                    </button>
                </div>
            </div>
        </div>

        <!-- HØJRE SIDE: Customer Liste -->
        <div class="customer-list-container">
            <div class="dash-card">
                <div class="dash-card-header">
                    <span class="dash-card-title">Existing Customers (0)</span>
                </div>

                <div class="customer-list">
                    <!-- Customer items vil være her -->
                    <div class="empty-state">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                        </svg>
                        <p>No customers yet</p>
                    </div>
                </div>
            </div>
        </div>

    </div>
</EditForm>

