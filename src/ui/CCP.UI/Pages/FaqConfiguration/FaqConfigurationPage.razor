@page "/faq-configuration"
<div class="container-shell">
    <div class="content">
        <div class="header">
            <h1 class="title">FAQ Management</h1>
            <p class="subtitle">Manage and organize your frequently asked questions</p>
        </div>

        <div class="config-section">
            <h2 class="config-section-title">FAQ Configuration</h2>

            <div class="toolbar">
                <button class="btn btn-primary" onclick="createNewFAQ()">+ Create New FAQ</button>
                <div class="search-wrapper">
                    <svg class="search-icon"
                         width="15"
                         height="15"
                         viewBox="0 0 16 16"
                         fill="none">
                        <circle cx="7"
                                cy="7"
                                r="4.5"
                                stroke="currentColor"
                                stroke-width="1.4" />
                        <path d="M10.5 10.5l3 3"
                              stroke="currentColor"
                              stroke-width="1.4"
                              stroke-linecap="round" />
                    </svg>
                    <input aria-label="Search FAQ"
                           type="text"
                           id="search"
                           placeholder="Search questions and answers…" />
                </div>
            </div>
            <div class="faq-table">
                <div class="table-head">
                    <div class="th">Question</div>
                    <div class="th">Category</div>
                    <div class="th" style="text-align: right;">Actions</div>
                </div>
                <div class="faq-rows">
                    <div class="faq-row">
                        <div class="faq-row-main" onclick="toggleExpand(this)">
                            <div class="row-question">
                                <div class="question-text">What is the return policy?</div>
                            </div>
                            <div class="row-category">
                                <span class="badge">General</span>
                            </div>
                            <div class="row-actions">
                                <button class="icon-btn edit-btn" title="Edit this question" onclick="event.stopPropagation(); toggleExpand(this.closest('.faq-row-main'));">
                                    <svg viewBox="0 0 16 16" fill="none"><path d="M2 13.5h1.5L11 5.5 9.5 4 2 11.5V13.5Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                                </button>
                                <button class="icon-btn delete-btn" title="Delete this question" onclick="event.stopPropagation();">
                                    <svg viewBox="0 0 16 16" fill="none"><path d="M3 4h10M6 4V2h4v2M5 4l1 8h4l1-8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                                </button>
                            </div>
                        </div>
                        <div class="faq-expand">
                            <div class="expand-content">
                                <div class="expand-grid">
                                    <div class="field">
                                        <label class="field-label">Question</label>
                                        <input type="text" class="field-input" value="What is the return policy?" placeholder="Enter question">
                                    </div>
                                    <div class="field">
                                        <label class="field-label">Answer</label>
                                        <textarea class="field-input" placeholder="Enter answer">Our return policy allows customers to return products within 30 days of purchase for a full refund. To initiate a return, please contact our customer service team with your order details.</textarea>
                                    </div>
                                    <div class="field">
                                        <label class="field-label">Category</label>
                                        <select class="field-input">
                                            <option>General</option>
                                            <option>Pricing</option>
                                            <option>Technical</option>
                                            <option>Account</option>
                                            <option>Policies</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="expand-footer">
                                    <button class="btn btn-primary" onclick="saveFAQ(event)">Save Changes</button>
                                    <button class="btn btn-secondary" onclick="event.stopPropagation(); cancelEdit(this)">Cancel</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="config-section">
                <h2 class="config-section-title">Trusted Domains Configuration</h2>

                <div class="domain-form">
                    <div class="form-group">
                        <label for="domain-input" class="form-label">Add Trusted Domain</label>
                        <div class="form-input-group">
                            <input type="text"
                                   id="domain-input"
                                   class="domain-input"
                                   placeholder="e.g., example.com"
                                   aria-label="Enter trusted domain" />
                            <button class="btn btn-primary">Save Domain</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
