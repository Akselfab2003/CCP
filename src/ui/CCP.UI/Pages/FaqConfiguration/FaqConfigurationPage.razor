@page "/faq-configuration"
@layout CCPLayout
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using CCP.Shared.ValueObjects
@attribute [Authorize(Roles = UserRolesExtensions.ConfigureChatbotRoleString)]
<div class="container-shell">
    <div class="content">
        <div class="header">
            <h1 class="title">FAQ Management</h1>
            <p class="subtitle">Manage and organize your frequently asked questions</p>
        </div>

        <div class="config-section">
            <h2 class="config-section-title">FAQ Configuration</h2>

            <div class="toolbar">
                <button class="btn btn-primary" @onclick="(() => StartCreateFaq())">+ Create New FAQ</button>
                <div class="search-wrapper">
                    <svg class="search-icon"
                         width="15"
                         height="15"
                         viewBox="0 0 16 16"
                         fill="none">
                        <circle cx="7"
                                cy="7"
                                r="4.5"
                                stroke="currentColor"
                                stroke-width="1.4" />
                        <path d="M10.5 10.5l3 3"
                              stroke="currentColor"
                              stroke-width="1.4"
                              stroke-linecap="round" />
                    </svg>
                    <input aria-label="Search FAQ"
                           type="text"
                           id="search"
                           placeholder="Search questions and answers…" />
                </div>
            </div>
            <div class="faq-table">
                <div class="table-head">
                    <div class="th">Question</div>
                    <div class="th">Category</div>
                    <div class="th" style="text-align: right;">Actions</div>
                </div>
                <div class="faq-rows">
                    @if (IsCreatingNewEntry && NewFaqEntry != null)
                    {
                        <div class="faq-row expanded">
                            <div class="faq-row-main">
                                <div class="row-question">
                                    <div class="question-text">
                                        New Question
                                    </div>
                                </div>
                                <div class="row-category">
                                    <span class="badge">General</span>

                                </div>
                                <div class="row-actions">
                                    <button class="icon-btn edit-btn" title="Edit this question" @onclick="() => CancelCreateFaq()" @onclick:stopPropagation>
                                        <svg viewBox="0 0 16 16" fill="none"><path d="M2 13.5h1.5L11 5.5 9.5 4 2 11.5V13.5Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                                    </button>
                                    <button class="icon-btn delete-btn" title="Delete this question" @onclick="() => CancelCreateFaq()">
                                        <svg viewBox="0 0 16 16" fill="none"><path d="M3 4h10M6 4V2h4v2M5 4l1 8h4l1-8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                                    </button>
                                </div>
                            </div>
                            <div class="faq-expand">
                                <div class="expand-content">
                                    <div class="expand-grid">
                                        <div class="field">
                                            <label class="field-label">Question</label>
                                            <input type="text" class="field-input" placeholder="Enter question" @bind="NewFaqEntry.Question" />
                                        </div>
                                        <div class="field">
                                            <label class="field-label">Answer</label>
                                            <textarea class="field-input" placeholder="Enter answer" @bind="NewFaqEntry.Answer"></textarea>
                                        </div>
                                        <div class="field">
                                            <label class="field-label">Category</label>
                                            <select class="field-input" @bind="NewFaqEntry.Category">
                                                <option>General</option>
                                                <option>Pricing</option>
                                                <option>Technical</option>
                                                <option>Account</option>
                                                <option>Policies</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="expand-footer">
                                        <button class="btn btn-primary" @onclick="SaveNewFaqEntry">Save</button>
                                        <button class="btn btn-secondary" @onclick="CancelCreateFaq">Cancel</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    @foreach (var faq in _faqEntries)
                    {
                        <div class="faq-row @(ExpandedFaqId == faq.Id ? "expanded" : "")">
                            <div class="faq-row-main" @onclick="() => ToggleFaqEntry(faq.Id)">
                                <div class="row-question">
                                    <div class="question-text">@faq.Question</div>
                                </div>
                                <div class="row-category">
                                    <span class="badge">@faq.Category</span>
                                </div>
                                <div class="row-actions">
                                    <button class="icon-btn edit-btn" title="Edit this question" @onclick="() => ToggleFaqEntry(faq.Id)" @onclick:stopPropagation>
                                        <svg viewBox="0 0 16 16" fill="none"><path d="M2 13.5h1.5L11 5.5 9.5 4 2 11.5V13.5Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                                    </button>
                                    <button class="icon-btn delete-btn" title="Delete this question" @onclick="() => DeleteFaqEntry(faq.Id)">
                                        <svg viewBox="0 0 16 16" fill="none"><path d="M3 4h10M6 4V2h4v2M5 4l1 8h4l1-8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                                    </button>
                                </div>
                            </div>
                            @if (ExpandedFaqId == faq.Id)
                            {
                                <div class="faq-expand">
                                    <div class="expand-content">
                                        <div class="expand-grid">
                                            <div class="field">
                                                <label class="field-label">Question</label>
                                                <input type="text" class="field-input" @bind-value="@faq.Question" placeholder="Enter question">
                                            </div>
                                            <div class="field">
                                                <label class="field-label">Answer</label>
                                                <textarea class="field-input" @bind="@faq.Answer" placeholder="Enter answer"></textarea>
                                            </div>
                                            <div class="field">
                                                <label class="field-label">Category</label>
                                                <select class="field-input" @bind="faq.Category">
                                                    <option>General</option>
                                                    <option>Pricing</option>
                                                    <option>Technical</option>
                                                    <option>Account</option>
                                                    <option>Policies</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="expand-footer">
                                            <button class="btn btn-primary" @onclick="() => SaveFaqEntry(faq)">Save Changes</button>
                                            <button class="btn btn-secondary" @onclick="() => CancelEdit()">Cancel</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="config-section">
                <h2 class="config-section-title">Trusted Domains Configuration</h2>

                <div class="domain-form">
                    <div class="form-group">
                        <label for="domain-input" class="form-label">Chatbot Domain configuration</label>
                        <div class="form-input-group">
                            <input type="text"
                                   id="domain-input"
                                   class="domain-input"
                                   placeholder="e.g., example.com"
                                   @bind-value="Domain"
                                   aria-label="Enter trusted domain" />
                            <button class="btn btn-primary" @onclick="SaveUpdatedDomain">Save Domain</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
