@using Microsoft.AspNetCore.Authorization
@using CCP.Shared.UIContext
@using CCP.Shared.ValueObjects
@using CCP.UI.Components.CreateTicket
@using CCP.UI.Layout
@page "/tickets/create"
@attribute [Authorize(Roles = UserRolesExtensions.CreateTicketsRoleString)]
@layout CCPLayout
@inject IUIUserContext UserContext

@if (UserContext.Role == UserRole.Customer)
{
    <CreateTicketCustomer />
}
else if (UserContext.Role == UserRole.Supporter)
{
    <CreateTicketSupporter />
}
else if (UserContext.Role == UserRole.Manager || UserContext.Role == UserRole.Admin)
{
    <CreateTicketManager />
}
