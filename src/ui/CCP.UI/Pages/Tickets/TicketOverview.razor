@using Microsoft.AspNetCore.Authorization
@page "/tickets"
@attribute [Authorize]
@layout CCPLayout

<HeadContent>
    <link rel="stylesheet" href="CCP.UI.styles.css" />
</HeadContent>

<div class="to-wrap">

    <div class="to-header">
        <div class="to-header-top">
            <h2 class="to-title">Ticket Overview</h2>
            <span class="to-count-badge">@_tickets.Count</span>
        </div>
        <p class="to-subtitle">Manage and assign support tickets</p>
    </div>

    @if (_errorMessage is not null)
    {
        <div class="to-error-banner">
            <span>@_errorMessage</span>
            <button class="to-error-dismiss" @onclick="() => _errorMessage = null">×</button>
        </div>
    }

    <div class="to-filter-row">
        @{
            var filterLabels = new Dictionary<string, string>
            {
                ["All"] = "All",
                ["Open"] = "Open",
                ["WaitingForCustomer"] = "Waiting for Customer",
                ["WaitingForSupport"] = "Waiting for Support",
                ["Closed"] = "Closed",
                ["Blocked"] = "Blocked",
                ["Unassigned"] = "Unassigned"
            };
        }
        @foreach (var filter in filterLabels)
        {
            <button class="to-filter @(_statusFilter == filter.Key ? "active" : "")"
                    @onclick="() => SetFilter(filter.Key)">
                @filter.Value
            </button>
        }
    </div>

    @if (_isLoading)
    {
        <div class="to-loading">
            <svg class="to-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
            </svg>
            Loading tickets...
        </div>
    }
    else if (!_filteredTickets.Any())
    {
        <div class="to-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" />
                <rect x="9" y="3" width="6" height="4" rx="1" />
                <path d="M9 12h6M9 16h4" />
            </svg>
            <p>No tickets found for <strong>@_statusFilter</strong></p>
        </div>
    }
    else
    {
        <div class="to-table-wrap">
            <table class="to-table">
                <thead>
                    <tr>
                        <th class="to-col-id">#</th>
                        <th>Title</th>
                        <th class="to-col-status">Status</th>
                        <th class="to-col-assign">Assigned To</th>
                        <th class="to-col-created">Created</th>
                        <th class="to-col-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in PagedTickets)
                    {
                        <tr class="to-row" @onclick="() => OpenPanel(ticket)">
                            <td class="to-cell-id">#@ticket.Id</td>
                            <td class="to-cell-title">@ticket.Title</td>
                            <td>
                                <span class="to-status-pill @GetStatusTagClass(ticket.Status)">
                                    @GetStatusLabel(ticket.Status)
                                </span>
                            </td>
                            <td>
                                @if (ticket.AssignedUserId is null)
                                {
                                    <span class="to-assigned-pill to-assigned-unassigned">Unassigned</span>
                                }
                                else
                                {
                                    <span class="to-assigned-pill @GetAssigneePillClass(ticket.AssignedUserId)">
                                        @GetAssigneeName(ticket.AssignedUserId)
                                    </span>
                                }
                            </td>
                            <td class="to-cell-muted">
                                @(ticket.CreatedAt?.ToLocalTime().ToString("MMM d, yyyy") ?? "—")
                            </td>
                            <td @onclick:stopPropagation="true">
                                <div class="to-cell-actions">
                                    @if (ticket.AssignedUserId != UserContext.UserId)
                                    {
                                        <button class="to-action-btn to-action-btn--primary"
                                                @onclick="() => SelfAssignAsync(ticket.Id)"
                                                disabled="@_isAssigning">
                                            Assign to me
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="to-assigned-indicator">Assigned to you</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Pagination — only shown when there's more than one page *@
        @if (TotalPages > 1)
        {
            <div class="to-pagination">
                <span class="to-pagination-info">
                    Page @_currentPage of @TotalPages
                    <span class="to-pagination-count">(@_filteredTickets.Count tickets)</span>
                </span>
                <div class="to-pagination-controls">
                    <button class="to-page-btn" @onclick="() => GoToPage(1)" disabled="@(_currentPage == 1)" title="First page">
                        «
                    </button>
                    <button class="to-page-btn" @onclick="() => GoToPage(_currentPage - 1)" disabled="@(_currentPage == 1)" title="Previous page">
                        ‹
                    </button>

                    @* Show up to 5 page numbers centred around current page *@
                    @{
                        int start = Math.Max(1, _currentPage - 2);
                        int end = Math.Min(TotalPages, start + 4);
                        start = Math.Max(1, end - 4); // re-clamp start if end was capped
                    }
                    @for (int p = start; p <= end; p++)
                    {
                        var pageNum = p;
                        <button class="to-page-btn @(pageNum == _currentPage ? "active" : "")"
                                @onclick="() => GoToPage(pageNum)">
                            @pageNum
                        </button>
                    }

                    <button class="to-page-btn" @onclick="() => GoToPage(_currentPage + 1)" disabled="@(_currentPage == TotalPages)" title="Next page">
                        ›
                    </button>
                    <button class="to-page-btn" @onclick="() => GoToPage(TotalPages)" disabled="@(_currentPage == TotalPages)" title="Last page">
                        »
                    </button>
                </div>
            </div>
        }
    }

</div>

<div class="to-panel-backdrop @(_isPanelOpen ? "open" : "")" @onclick="ClosePanel"></div>

<div class="to-panel @(_isPanelOpen ? "open" : "")">
    @if (_selectedTicket is not null)
    {
        <div class="to-panel-header">
            <div class="to-panel-header-left">
                <span class="to-panel-ticket-id">#@_selectedTicket.Id</span>
                <span class="to-status-pill @GetStatusTagClass(_selectedTicket.Status)">
                    @GetStatusLabel(_selectedTicket.Status)
                </span>
            </div>
            <button class="to-panel-close" @onclick="ClosePanel">×</button>
        </div>

        <div class="to-panel-body">

            <h3 class="to-panel-title">@_selectedTicket.Title</h3>

            <div class="to-panel-meta">
                <div class="to-panel-meta-row">
                    <span class="to-panel-meta-label">Created</span>
                    <span class="to-panel-meta-value">
                        @(_selectedTicket.CreatedAt?.ToLocalTime().ToString("MMM d, yyyy HH:mm") ?? "—")
                    </span>
                </div>
                <div class="to-panel-meta-row">
                    <span class="to-panel-meta-label">Customer</span>
                    <span class="to-panel-meta-value to-panel-mono">
                        @(_selectedTicket.CustomerId.HasValue
                            ? _selectedTicket.CustomerId.Value.ToString()[..8] + "…"
                            : "—")
                    </span>
                </div>
                <div class="to-panel-meta-row">
                    <span class="to-panel-meta-label">Assigned to</span>
                    <span class="to-panel-meta-value">
                        @if (_selectedTicket.AssignedUserId is null)
                        {
                            <span class="to-assigned-pill to-assigned-unassigned">Unassigned</span>
                        }
                        else if (_selectedTicket.AssignedUserId == UserContext.UserId)
                        {
                            <span class="to-assigned-pill to-assigned-you">You</span>
                        }
                        else
                        {
                            <span class="to-assigned-pill to-assigned-other">
                                @GetAssigneeName(_selectedTicket.AssignedUserId)
                            </span>
                        }
                    </span>
                </div>
            </div>

            <div class="to-panel-divider"></div>

            <!-- Assignment actions -->
            <div class="to-panel-section">
                <span class="to-panel-section-label">Assignment</span>

                @if (_selectedTicket.AssignedUserId != UserContext.UserId)
                {
                    <button class="to-action-btn to-action-btn--primary"
                            style="width:100%; justify-content:center; margin-bottom:8px;"
                            @onclick="SelfAssignFromPanelAsync"
                            disabled="@_isUpdatingAssignment">
                        Assign to me
                    </button>
                }
                else
                {
                    <p class="to-assigned-indicator" style="margin-bottom:8px;">
                        ✓ Assigned to you
                    </p>
                }

                @if (IsManager)
                {
                    <div class="to-panel-search-wrap">
                        <input class="to-modal-input"
                               placeholder="Search supporters by name…"
                               value="@_supporterSearchTerm"
                               @oninput="HandleSupporterSearchInput" />
                        @if (_isSearching)
                        {
                            <p class="to-panel-search-hint">Searching…</p>
                        }
                        @if (_searchError is not null)
                        {
                            <p class="to-modal-error">@_searchError</p>
                        }
                        @if (_supporterSearchResults.Any())
                        {
                            <ul class="to-panel-search-results">
                                @foreach (var supporter in _supporterSearchResults)
                                {
                                    var s = supporter;
                                    <li class="to-panel-search-result"
                                        @onclick="() => AssignToSupporterAsync(s.userId)">
                                        <span class="to-panel-result-name">@s.name</span>
                                        <span class="to-panel-result-email">@s.email</span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                }
            </div>

            <div class="to-panel-divider"></div>

            <!-- Go to inbox -->
            @if (CanGoToTicket(_selectedTicket))
            {
                <button class="to-action-btn to-action-btn--ghost"
                        style="width:100%; justify-content:center;"
                        @onclick="() => NavigateToTicket(_selectedTicket.Id)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" width="14" height="14">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                        <polyline points="22,6 12,13 2,6" />
                    </svg>
                    Go to Ticket
                </button>
            }

        </div>
    }
</div>
