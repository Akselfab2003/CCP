@using Microsoft.AspNetCore.Authorization
@using CCP.Shared.ValueObjects
@using CCP.UI.Layout
@page "/tickets/{TicketId:int}"
@attribute [Authorize]
@layout CCPLayout

<div class="td-wrap">

    @if (_isLoading)
    {
        <div class="td-loading">
            <svg class="td-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
            </svg>
            Loading ticket...
        </div>
    }
    else if (_errorMessage is not null)
    {
        <div class="td-error">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            @_errorMessage
        </div>
    }
    else if (_ticket is not null)
    {
        <!-- Header -->
        <div class="td-chat-header">
            <div class="td-chat-header-left">
                <button class="td-back-btn" @onclick="NavigateBack" title="Back to tickets">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16">
                        <polyline points="15 18 9 12 15 6" />
                    </svg>
                </button>
                <div>
                    <div class="td-chat-name">@_ticket.Title</div>
                    <div class="td-chat-sub">#TK-@_ticket.Id · @GetStatusLabel(_ticket.Status)</div>
                </div>
            </div>
            <div class="td-chat-header-right">
                <span class="td-tag @GetStatusTagClass(_ticket.Status)">
                    @GetStatusLabel(_ticket.Status)
                </span>
                <div class="td-status-group">
                    <button class="td-status-btn @(_ticket.Status == 0 ? "td-status-btn--active td-tag-teal" : "")"
                            @onclick="() => UpdateTicketStatusAsync(TicketStatus.Open)">
                        Open
                    </button>
                    <button class="td-status-btn @(_ticket.Status == 1 ? "td-status-btn--active td-tag-amber" : "")"
                            @onclick="() => UpdateTicketStatusAsync(TicketStatus.WaitingForCustomer)">
                        Waiting for Customer
                    </button>
                    <button class="td-status-btn @(_ticket.Status == 2 ? "td-status-btn--active td-tag-indigo" : "")"
                            @onclick="() => UpdateTicketStatusAsync(TicketStatus.WaitingForSupport)">
                        Waiting for Support
                    </button>
                    <button class="td-status-btn @(_ticket.Status == 3 ? "td-status-btn--active td-tag-slate" : "")"
                            @onclick="() => UpdateTicketStatusAsync(TicketStatus.Closed)">
                        Closed
                    </button>
                    <button class="td-status-btn @(_ticket.Status == 4 ? "td-status-btn--active td-tag-red" : "")"
                            @onclick="() => UpdateTicketStatusAsync(TicketStatus.Blocked)">
                        Blocked
                    </button>
                </div>
                <!-- Sidebar toggle -->
                <button class="td-sidebar-toggle @(_sidebarOpen ? "td-sidebar-toggle--active" : "")"
                        @onclick="() => _sidebarOpen = !_sidebarOpen"
                        title="@(_sidebarOpen ? "Hide ticket info" : "Show ticket info")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <line x1="15" y1="3" x2="15" y2="21" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- Body: chat + optional sidebar -->
        <div class="td-body">

            <!-- Chat column -->
            <div class="td-chat">

                <div class="td-messages">
                    @if (_isLoadingMessages)
                    {
                        <div class="td-messages-state">
                            <svg class="td-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                            </svg>
                            Loading messages...
                        </div>
                    }
                    else if (!_messages.Any())
                    {
                        <div class="td-messages-state">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" style="color:var(--ccp-border-mid);">
                                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
                            </svg>
                            No messages yet. Start the conversation!
                        </div>
                    }
                    else
                    {
                        @foreach (var msg in _messages)
                        {
                            @if (msg.IsInternalNote)
                            {
                                <div class="td-msg td-msg--note">
                                    <div class="td-msg-note-label">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
                                            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                                            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                                        </svg>
                                        Internal note — @GetDisplayName(msg.UserId)
                                    </div>
                                    <div class="td-msg-bubble td-msg-bubble--note">@msg.Content</div>
                                    <div class="td-msg-meta" style="padding-left:0;">
                                        @msg.CreatedAtUtc?.ToLocalTime().ToString("HH:mm")
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="td-msg @(IsOwnMessage(msg) ? "td-msg--out" : "td-msg--in")">
                                    @if (!IsOwnMessage(msg))
                                    {
                                        <div class="td-avatar td-msg-avatar" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">
                                            @GetInitials(msg.UserId)
                                        </div>
                                    }
                                    <div class="td-msg-body @(IsOwnMessage(msg) ? "td-msg-body--out" : "")">
                                        <div class="td-msg-meta @(IsOwnMessage(msg) ? "td-msg-meta--out" : "")">
                                            @GetDisplayName(msg.UserId)
                                            <span>·</span>
                                            @msg.CreatedAtUtc?.ToLocalTime().ToString("HH:mm")
                                        </div>
                                        <div class="td-msg-bubble @(IsOwnMessage(msg) ? "td-msg-bubble--out" : "td-msg-bubble--in")">
                                            @msg.Content
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>

                <div class="td-composer">
                    <div class="td-composer-tabs">
                        <button class="td-composer-tab @(!_isInternalNoteMode ? "active" : "")"
                                @onclick="() => _isInternalNoteMode = false">
                            Reply
                        </button>
                        <button class="td-composer-tab @(_isInternalNoteMode ? "active" : "")"
                                @onclick="() => _isInternalNoteMode = true">
                            Internal Note
                        </button>
                    </div>
                    <div class="td-composer-body">
                        <textarea class="td-composer-input"
                                  placeholder="@(_isInternalNoteMode ? "Write an internal note..." : "Write a reply...")"
                                  rows="3"
                                  style="@(_isInternalNoteMode ? "border-color:#f59e0b;background:rgba(245,158,11,0.04);" : "")"
                                  @bind="_newMessageContent"
                                  @onkeydown="HandleKeyDown" />
                        <div class="td-composer-footer">
                            <div></div>
                            <button class="td-send-btn"
                                    style="@(_isInternalNoteMode ? "background:#f59e0b;box-shadow:0 0 14px rgba(245,158,11,0.3);" : "")"
                                    @onclick="SendMessageAsync" disabled="@_isSending">
                                @(_isInternalNoteMode ? "Add Note" : "Send")
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                                    <line x1="22" y1="2" x2="11" y2="13" />
                                    <polygon points="22 2 15 22 11 13 2 9 22 2" />
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Info sidebar -->
            <aside class="td-sidebar @(_sidebarOpen ? "td-sidebar--open" : "")">

                <div class="td-sidebar-section">
                    <div class="td-sidebar-section-title">Ticket</div>
                    <div class="td-sidebar-row">
                        <span class="td-sidebar-label">ID</span>
                        <span class="td-sidebar-value td-sidebar-mono">#TK-@_ticket.Id</span>
                    </div>
                    <div class="td-sidebar-row">
                        <span class="td-sidebar-label">Status</span>
                        <span class="td-tag @GetStatusTagClass(_ticket.Status)" style="font-size:10px;">
                            @GetStatusLabel(_ticket.Status)
                        </span>
                    </div>
                    <div class="td-sidebar-row">
                        <span class="td-sidebar-label">Created</span>
                        <span class="td-sidebar-value">
                            @(_ticket.CreatedAt?.ToLocalTime().ToString("MMM d, yyyy") ?? "—")
                        </span>
                    </div>
                    <div class="td-sidebar-row">
                        <span class="td-sidebar-label">Time</span>
                        <span class="td-sidebar-value">
                            @(_ticket.CreatedAt?.ToLocalTime().ToString("HH:mm") ?? "—")
                        </span>
                    </div>
                </div>

                <div class="td-sidebar-divider"></div>

                <div class="td-sidebar-section">
                    <div class="td-sidebar-section-title">People</div>
                    <div class="td-sidebar-row">
                        <span class="td-sidebar-label">Customer</span>
                        <span class="td-sidebar-value">
                            @if (!_ticket.CustomerId.HasValue)
                            {
                                <span>—</span>
                            }
                            else if (_customerName is not null)
                            {
                                @_customerName
                            }
                            else
                            {
                                <span class="td-sidebar-mono">Loading…</span>
                            }
                        </span>
                    </div>
                    <div class="td-sidebar-row">
                        <span class="td-sidebar-label">Assigned to</span>
                        <span class="td-sidebar-value">
                            @if (_ticket.AssignedUserId is null)
                            {
                                <span class="td-assignee-pill td-assignee-unassigned">Unassigned</span>
                            }
                            else if (_ticket.AssignedUserId == UserContext.UserId)
                            {
                                <span class="td-assignee-pill td-assignee-you">You</span>
                            }
                            else
                            {
                                <span class="td-assignee-pill td-assignee-other">
                                    @GetAssigneeName(_ticket.AssignedUserId)
                                </span>
                            }
                        </span>
                    </div>
                </div>

                <div class="td-sidebar-divider"></div>

                <div class="td-sidebar-section">
                    <div class="td-sidebar-section-title">Messages</div>
                    <div class="td-sidebar-row">
                        <span class="td-sidebar-label">Total</span>
                        <span class="td-sidebar-value">@_messages.Count(m => !m.IsInternalNote)</span>
                    </div>
                    <div class="td-sidebar-row">
                        <span class="td-sidebar-label">Internal notes</span>
                        <span class="td-sidebar-value">@_messages.Count(m => m.IsInternalNote)</span>
                    </div>
                </div>

            </aside>

        </div>
    }

</div>
