@page "/my-tickets"
@using CCP.UI.Components.MyTicketsComponents
@using CCP.Shared.UIContext
@using CCP.Shared.ValueObjects
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@layout CCPLayout
@inject IUIUserContext UserContext

@if (UserContext.Role == UserRole.Customer)
{
    <MyTicketsCustomer />
}
else
{
    <MyTicketsInternalUser />
}
