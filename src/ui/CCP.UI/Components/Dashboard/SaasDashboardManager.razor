@using CCP.Shared.UIContext
@using TicketService.Sdk.Dtos

<!-- Greeting -->
<div class="dash-greeting">
    <div>
        <h2 class="dash-greeting-title">Good morning, @UserContext.FirstName 👋</h2>
        <p class="dash-greeting-sub">Here's what's happening across your queue today.</p>
    </div>
    <span class="dash-date">@DateTime.Now.ToString("dddd, MMMM d")</span>
</div>

<!-- Stat Cards -->
<div class="dash-stats">
    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Open Tickets</span>
            <span class="dash-stat-icon" style="color:#818cf8;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" />
                    <rect x="9" y="3" width="6" height="4" rx="1" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">
            @if (_stats is null)
            {
                <svg class="dash-stat-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                </svg>
            }
            else
            {
                @_stats.OpenTickets
            }
        </div>
        <div class="dash-stat-delta delta-neutral">across all tickets</div>
    </div>

    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Resolved Today</span>
            <span class="dash-stat-icon" style="color:#34d399;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <polyline points="20 6 9 17 4 12" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">
            @if (_stats is null)
            {
                <svg class="dash-stat-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                </svg>
            }
            else
            {
                @_stats.ClosedToday
            }
        </div>
        <div class="dash-stat-delta delta-neutral">in the last 24 hours</div>
    </div>

    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Avg. Response Time</span>
            <span class="dash-stat-icon" style="color:#f59e0b;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">
            @if (_stats is null)
            {
                <svg class="dash-stat-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                </svg>
            }
            else
            {
                @_stats.AvgResponseTime
            }
        </div>
        <div class="dash-stat-delta delta-neutral">avg. first response</div>
    </div>

    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Awaiting You</span>
            <span class="dash-stat-icon" style="color:#f87171;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 01-3.46 0" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">
            @if (_stats is null)
            {
                <svg class="dash-stat-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                </svg>
            }
            else
            {
                @_stats.AwaitingUser
            }
        </div>
        <div class="dash-stat-delta delta-neutral">needs your attention</div>
    </div>
</div>

<!-- Main content grid -->
<div class="dash-grid">

    <!-- Latest Updates -->
    <div class="dash-card dash-updates">
        <div class="dash-card-header">
            <span class="dash-card-title">Latest Updates</span>
            <a href="/tickets" class="dash-card-link">View all →</a>
        </div>

        <div class="dash-feed">

            @if (_feedEntries is null)
            {
                <div class="dash-feed-loading">
                    <svg class="dash-stat-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                    </svg>
                    Loading activity...
                </div>
            }
            else if (!_feedEntries.Any())
            {
                <div style="padding: 20px 0; text-align:center; color:var(--ccp-text-lo); font-size:13px;">
                    No recent activity yet.
                </div>
            }
            else
            {
                @foreach (var entry in _feedEntries)
                {
                    <div class="dash-feed-item dash-feed-item--clickable" @onclick="() => NavigateToTicket(entry.TicketId)">
                        <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">
                            @GetHistoryInitials(entry)
                        </div>
                        <div class="dash-feed-body">
                            <div class="dash-feed-top">
                                <span class="dash-feed-ticket">#TK-@entry.TicketId</span>
                                <span class="dash-feed-time">@GetRelativeTime(entry.OccurredAt)</span>
                            </div>
                            <p class="dash-feed-text">@GetHistoryDescription(entry)</p>
                            <div class="dash-feed-tags">
                                <span class="dash-tag @GetHistoryTagClass(entry)">@GetHistoryTagLabel(entry)</span>
                            </div>
                        </div>
                        <span class="dash-feed-dot @GetHistoryDotClass(entry)"></span>
                    </div>
                }
            }

        </div>
    </div>

    <!-- Team Performance -->
    <div class="dash-card dash-team">
        <div class="dash-card-header">
            <span class="dash-card-title">Team Performance</span>
            <span class="dash-card-sub">Last 7 days</span>
        </div>

        <div class="dash-team-list">

            @if (_stats is null)
            {
                <div class="dash-feed-loading">
                    <svg class="dash-stat-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" width="20" height="20">
                        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                    </svg>
                    Loading...
                </div>
            }
            else if (!_stats.TeamPerformance.Any())
            {
                <div style="font-size:13px; color:var(--ccp-text-lo); text-align:center; padding: 16px 0;">
                    No resolved tickets this week.
                </div>
            }
            else
            {
                var maxCount = _stats.TeamPerformance.Max(p => p.ResolvedCount);
                @foreach (var supporter in _stats.TeamPerformance)
                {
                    var name = _supporterNames.TryGetValue(supporter.UserId, out var n) ? n : supporter.UserId.ToString()[..8] + "…";
                    var barWidth = maxCount > 0 ? (int)((supporter.ResolvedCount / (double)maxCount) * 100) : 0;
                    <div class="dash-team-row">
                        <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">
                            @GetInitials(name)
                        </div>
                        <div class="dash-team-info">
                            <span class="dash-team-name">@name</span>
                            <span class="dash-team-stat">@supporter.ResolvedCount resolved</span>
                        </div>
                        <div class="dash-team-bar-wrap">
                            <div class="dash-team-bar" style="width:@(barWidth)%;background:#6366f1;"></div>
                        </div>
                    </div>
                }
            }

        </div>
    </div>

</div>
