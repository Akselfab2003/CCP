@using CCP.Shared.UIContext

@inject IUIUserContext UserContext

<!-- Greeting -->
<div class="dash-greeting">
    <div>
        <h2 class="dash-greeting-title">Good morning, @UserContext.FirstName 👋</h2>
        <p class="dash-greeting-sub">Here's what's happening across your queue today.</p>
    </div>
    <span class="dash-date">@DateTime.Now.ToString("dddd, MMMM d")</span>
</div>

<!-- Stat Cards -->
<div class="dash-stats">
    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Open Tickets</span>
            <span class="dash-stat-icon" style="color:#818cf8;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" />
                    <rect x="9" y="3" width="6" height="4" rx="1" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">247</div>
        <div class="dash-stat-delta delta-up">↑ 8% vs last week</div>
    </div>

    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Resolved Today</span>
            <span class="dash-stat-icon" style="color:#34d399;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <polyline points="20 6 9 17 4 12" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">38</div>
        <div class="dash-stat-delta delta-up">↑ 12% vs yesterday</div>
    </div>

    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Avg. Response Time</span>
            <span class="dash-stat-icon" style="color:#f59e0b;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">2.4h</div>
        <div class="dash-stat-delta delta-down">↓ 5 min slower</div>
    </div>

    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Awaiting You</span>
            <span class="dash-stat-icon" style="color:#f87171;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 01-3.46 0" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">12</div>
        <div class="dash-stat-delta delta-neutral">needs your attention</div>
    </div>
</div>

<!-- Main content grid -->
<div class="dash-grid">

    <!-- Latest Updates -->
    <div class="dash-card dash-updates">
        <div class="dash-card-header">
            <span class="dash-card-title">Latest Updates</span>
            <a href="/tickets" class="dash-card-link">View all →</a>
        </div>

        <div class="dash-feed">

            <div class="dash-feed-item">
                <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">AK</div>
                <div class="dash-feed-body">
                    <div class="dash-feed-top">
                        <span class="dash-feed-ticket">#TK-8821</span>
                        <span class="dash-feed-time">12 min ago</span>
                    </div>
                    <p class="dash-feed-text"><strong>Alex Kim</strong> replied — Payment gateway returning 500 error on checkout</p>
                    <div class="dash-feed-tags">
                        <span class="dash-tag tag-red">Urgent</span>
                        <span class="dash-tag tag-slate">Bug</span>
                    </div>
                </div>
                <span class="dash-feed-dot dot-red"></span>
            </div>

            <div class="dash-feed-item">
                <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#ec4899,#f43f5e)">SM</div>
                <div class="dash-feed-body">
                    <div class="dash-feed-top">
                        <span class="dash-feed-ticket">#TK-8820</span>
                        <span class="dash-feed-time">1 hr ago</span>
                    </div>
                    <p class="dash-feed-text"><strong>Sam Miller</strong> changed status to <span class="dash-tag tag-teal" style="display:inline;padding:1px 6px;font-size:10px;">Open</span> — Unable to export data to CSV</p>
                    <div class="dash-feed-tags">
                        <span class="dash-tag tag-teal">Open</span>
                        <span class="dash-tag tag-indigo">Feature</span>
                    </div>
                </div>
                <span class="dash-feed-dot dot-amber"></span>
            </div>

            <div class="dash-feed-item">
                <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#10b981,#059669)">RP</div>
                <div class="dash-feed-body">
                    <div class="dash-feed-top">
                        <span class="dash-feed-ticket">#TK-8818</span>
                        <span class="dash-feed-time">3 hrs ago</span>
                    </div>
                    <p class="dash-feed-text"><strong>Riley Park</strong> added a note — Wrong amount charged on Pro plan renewal</p>
                    <div class="dash-feed-tags">
                        <span class="dash-tag tag-amber">Pending</span>
                        <span class="dash-tag tag-slate">Billing</span>
                    </div>
                </div>
                <span class="dash-feed-dot dot-amber"></span>
            </div>

            <div class="dash-feed-item">
                <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#0ea5e9,#6366f1)">CL</div>
                <div class="dash-feed-body">
                    <div class="dash-feed-top">
                        <span class="dash-feed-ticket">#TK-8817</span>
                        <span class="dash-feed-time">5 hrs ago</span>
                    </div>
                    <p class="dash-feed-text"><strong>Chris Lee</strong> replied — SSO login fails with Okta integration</p>
                    <div class="dash-feed-tags">
                        <span class="dash-tag tag-teal">Open</span>
                        <span class="dash-tag tag-slate">Bug</span>
                    </div>
                </div>
                <span class="dash-feed-dot dot-green"></span>
            </div>

            <div class="dash-feed-item">
                <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#8b5cf6,#a78bfa)">MJ</div>
                <div class="dash-feed-body">
                    <div class="dash-feed-top">
                        <span class="dash-feed-ticket">#TK-8814</span>
                        <span class="dash-feed-time">Yesterday</span>
                    </div>
                    <p class="dash-feed-text"><strong>Morgan J.</strong> closed ticket — Request for custom webhook endpoint config</p>
                    <div class="dash-feed-tags">
                        <span class="dash-tag tag-slate">Closed</span>
                        <span class="dash-tag tag-indigo">Feature</span>
                    </div>
                </div>
                <span class="dash-feed-dot dot-slate"></span>
            </div>

        </div>
    </div>

    <!-- Team Performance -->
    <div class="dash-card dash-team">
        <div class="dash-card-header">
            <span class="dash-card-title">Team Performance</span>
            <span class="dash-card-sub">This week</span>
        </div>

        <div class="dash-team-list">

            <div class="dash-team-row">
                <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">JD</div>
                <div class="dash-team-info">
                    <span class="dash-team-name">Jordan Davis</span>
                    <span class="dash-team-stat">24 resolved</span>
                </div>
                <div class="dash-team-bar-wrap">
                    <div class="dash-team-bar" style="width:88%;background:#6366f1;"></div>
                </div>
            </div>

            <div class="dash-team-row">
                <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#10b981,#059669)">AL</div>
                <div class="dash-team-info">
                    <span class="dash-team-name">Alex Lee</span>
                    <span class="dash-team-stat">19 resolved</span>
                </div>
                <div class="dash-team-bar-wrap">
                    <div class="dash-team-bar" style="width:70%;background:#10b981;"></div>
                </div>
            </div>

            <div class="dash-team-row">
                <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#ec4899,#f43f5e)">SM</div>
                <div class="dash-team-info">
                    <span class="dash-team-name">Sam Miller</span>
                    <span class="dash-team-stat">16 resolved</span>
                </div>
                <div class="dash-team-bar-wrap">
                    <div class="dash-team-bar" style="width:58%;background:#ec4899;"></div>
                </div>
            </div>

            <div class="dash-team-row">
                <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#10b981,#059669)">RP</div>
                <div class="dash-team-info">
                    <span class="dash-team-name">Riley Park</span>
                    <span class="dash-team-stat">11 resolved</span>
                </div>
                <div class="dash-team-bar-wrap">
                    <div class="dash-team-bar" style="width:40%;background:#f59e0b;"></div>
                </div>
            </div>

            <div class="dash-team-row">
                <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#0ea5e9,#6366f1)">CL</div>
                <div class="dash-team-info">
                    <span class="dash-team-name">Chris Lee</span>
                    <span class="dash-team-stat">9 resolved</span>
                </div>
                <div class="dash-team-bar-wrap">
                    <div class="dash-team-bar" style="width:33%;background:#0ea5e9;"></div>
                </div>
            </div>

        </div>
    </div>

</div>
