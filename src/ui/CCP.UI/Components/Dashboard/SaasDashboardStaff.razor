@using CCP.Shared.UIContext
@using CCP.Shared.ValueObjects

<!-- Greeting -->
<div class="dash-greeting">
    <div>
        <h2 class="dash-greeting-title">Good morning, @UserContext.FirstName 👋</h2>
        <p class="dash-greeting-sub">Here's a summary of your assigned tickets and recent activity.</p>
    </div>
    <span class="dash-date">@DateTime.Now.ToString("dddd, MMMM d")</span>
</div>

<!-- Stat Cards -->
<div class="dash-stats">

    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Open Tickets</span>
            <span class="dash-stat-icon" style="color:#818cf8;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" />
                    <rect x="9" y="3" width="6" height="4" rx="1" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">
            @if (_allOpenCount is null)
            {
                <svg class="dash-stat-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                </svg>
            }
            else
            {
                @_allOpenCount
            }
        </div>
        <div class="dash-stat-delta delta-neutral">across all tickets</div>
    </div>

    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Awaiting You</span>
            <span class="dash-stat-icon" style="color:#f87171;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 01-3.46 0" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">
            @if (_waitingForSupporterCount is null)
            {
                <svg class="dash-stat-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                </svg>
            }
            else
            {
                @_waitingForSupporterCount
            }
        </div>
        <div class="dash-stat-delta delta-neutral">needs your attention</div>
    </div>

    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Awaiting Customer</span>
            <span class="dash-stat-icon" style="color:#34d399;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">
            @if (_waitingForCustomerCount is null)
            {
                <svg class="dash-stat-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                </svg>
            }
            else
            {
                @_waitingForCustomerCount
            }
        </div>
        <div class="dash-stat-delta delta-neutral">waiting for customer reply</div>
    </div>

    <div class="dash-stat-card">
        <div class="dash-stat-header">
            <span class="dash-stat-label">Assigned to You</span>
            <span class="dash-stat-icon" style="color:#a78bfa;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </span>
        </div>
        <div class="dash-stat-value">
            @if (_assignedCount is null)
            {
                <svg class="dash-stat-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                </svg>
            }
            else
            {
                @_assignedCount
            }
        </div>
        <div class="dash-stat-delta delta-neutral">open tickets assigned to you</div>
    </div>

</div>

<!-- Full-width updates feed -->
<div class="dash-card dash-updates staff-updates">
    <div class="dash-card-header">
        <span class="dash-card-title">Your Ticket Activity</span>
        <a href="/inbox" class="dash-card-link">View all →</a>
    </div>

    <div class="dash-feed">

        @if (_feedEntries is null)
        {
            <div class="dash-feed-loading">
                <svg class="dash-stat-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                </svg>
                Loading activity...
            </div>
        }
        else if (!_feedEntries.Any())
        {
            <div style="padding: 20px 0; text-align:center; color:var(--ccp-text-lo); font-size:13px;">
                No recent activity yet.
            </div>
        }
        else
        {
            @foreach (var entry in _feedEntries)
            {
                <div class="dash-feed-item dash-feed-item--clickable" @onclick="() => NavigateToTicket(entry.TicketId)">
                    <div class="dash-feed-avatar" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">
                        @GetInitials(entry.SenderName)
                    </div>
                    <div class="dash-feed-body">
                        <div class="dash-feed-top">
                            <span class="dash-feed-ticket">#TK-@entry.TicketId</span>
                            <span class="dash-feed-time">@GetRelativeTime(entry.OccurredAt)</span>
                        </div>
                        <p class="dash-feed-text">
                            <strong>@entry.SenderName</strong> @entry.ActionText — @entry.TicketTitle
                        </p>
                        <div class="dash-feed-tags">
                            <span class="dash-tag @GetStatusTagClass(entry.TicketStatus)">@GetStatusLabel(entry.TicketStatus)</span>
                        </div>
                    </div>
                    <span class="dash-feed-dot @GetDotClass(entry.TicketStatus)"></span>
                </div>
            }
        }

    </div>
</div>
