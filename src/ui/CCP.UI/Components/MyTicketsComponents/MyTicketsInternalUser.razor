@using Microsoft.AspNetCore.Authorization
@using CCP.Shared.UIContext
@using CCP.Shared.ValueObjects
@using TicketService.Sdk.Dtos
@attribute [Authorize]
@layout CCPLayout

<HeadContent>
    <link rel="stylesheet" href="CCP.UI.styles.css" />
</HeadContent>

<div class="mti-wrap">

    <!-- Header -->
    <div class="mti-header">
        <div class="mti-header-left">
            <h1 class="mti-title">My Assigned Tickets</h1>
            <p class="mti-subtitle">Tickets currently assigned to you</p>
        </div>
        <a href="/tickets/create" class="mti-new-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            New Ticket
        </a>
    </div>

    <!-- Summary strip -->
    @if (_tickets is not null)
    {
        <div class="mti-summary">
            <div class="mti-summary-item">
                <span class="mti-summary-value mti-summary-value--active">@_tickets.Count(t => t.Status == (int)TicketStatus.Open)</span>
                <span class="mti-summary-label">Open</span>
            </div>
            <div class="mti-summary-divider"></div>
            <div class="mti-summary-item">
                <span class="mti-summary-value mti-summary-value--reply">@_tickets.Count(t => t.Status == (int)TicketStatus.WaitingForCustomer || t.Status == (int)TicketStatus.WaitingForSupport)</span>
                <span class="mti-summary-label">Waiting</span>
            </div>
            <div class="mti-summary-divider"></div>
            <div class="mti-summary-item">
                <span class="mti-summary-value mti-summary-value--blocked">@_tickets.Count(t => t.Status == (int)TicketStatus.Blocked)</span>
                <span class="mti-summary-label">Blocked</span>
            </div>
            <div class="mti-summary-divider"></div>
            <div class="mti-summary-item">
                <span class="mti-summary-value mti-summary-value--closed">@_tickets.Count(t => t.Status == (int)TicketStatus.Closed)</span>
                <span class="mti-summary-label">Closed</span>
            </div>
        </div>
    }

    <!-- Filter tabs -->
    <div class="mti-filters">
        @foreach (var f in _filters)
        {
            <button class="mti-filter-btn @(_activeFilter == f.Key ? "mti-filter-btn--active" : "")"
                    @onclick="() => SetFilter(f.Key)">
                @f.Label
                @if (_tickets is not null)
                {
                    <span class="mti-filter-count @(_activeFilter == f.Key ? "mti-filter-count--active" : "")">@GetFilterCount(f.Key)</span>
                }
            </button>
        }
    </div>

    <!-- Search bar -->
    <div class="mti-search-wrap">
        <svg class="mti-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input class="mti-search-input"
               type="text"
               placeholder="Search your assigned tickets…"
               value="@_searchQuery"
               @oninput="SetSearch" />
        @if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            <button class="mti-search-clear" @onclick="() => { _searchQuery = string.Empty; _currentPage = 1; ApplyFilter(); StateHasChanged(); }">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="13" height="13">
                    <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        }
    </div>

    <!-- Content -->
    @if (_isLoading)
    {
        <div class="mti-loading">
            <svg class="mti-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
            </svg>
            <span>Loading your assigned tickets…</span>
        </div>
    }
    else if (_errorMessage is not null)
    {
        <div class="mti-error">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <span>@_errorMessage</span>
        </div>
    }
    else if (!_filtered.Any())
    {
        <div class="mti-empty">
            <div class="mti-empty-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="40" height="40">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" />
                    <rect x="9" y="3" width="6" height="4" rx="1" />
                    <path d="M9 12h6M9 16h4" />
                </svg>
            </div>
            @if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                <p class="mti-empty-title">No results for "@_searchQuery"</p>
                <p class="mti-empty-sub">Try a different search term or clear the search.</p>
            }
            else if (_activeFilter == "All")
            {
                <p class="mti-empty-title">No assigned tickets</p>
                <p class="mti-empty-sub">You have no tickets assigned to you right now.</p>
            }
            else
            {
                <p class="mti-empty-title">No @_filters.First(f => f.Key == _activeFilter).Label.ToLower() tickets</p>
                <p class="mti-empty-sub">Try a different filter to see your other tickets.</p>
            }
        </div>
    }
    else
    {
        <div class="mti-cards">
            @foreach (var ticket in PagedItems)
            {
                var statusInfo = GetStatusInfo(ticket.Status);
                <div class="mti-card" @onclick="() => NavigateToTicket(ticket.Id)">

                    <div class="mti-card-top">
                        <span class="mti-card-id">#TK-@ticket.Id</span>
                        <span class="mti-status-pill mti-status-pill--@statusInfo.CssKey">
                            <span class="mti-status-dot"></span>
                            @statusInfo.Label
                        </span>
                    </div>

                    <span class="mti-card-customer">@GetCustomerName(ticket.CustomerId)</span>

                    <h3 class="mti-card-title">@ticket.Title</h3>

                    <div class="mti-card-footer">
                        <span class="mti-card-date">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
                                <rect x="3" y="4" width="18" height="18" rx="2" />
                                <line x1="16" y1="2" x2="16" y2="6" />
                                <line x1="8" y1="2" x2="8" y2="6" />
                                <line x1="3" y1="10" x2="21" y2="10" />
                            </svg>
                            @GetRelativeDate(ticket.CreatedAt)
                        </span>
                        <span class="mti-card-action">
                            View ticket
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12">
                                <polyline points="9 18 15 12 9 6" />
                            </svg>
                        </span>
                    </div>

                </div>
            }
        </div>

        <!-- Pagination -->
        @if (TotalPages > 1)
        {
            <div class="mti-pagination">
                <span class="mti-page-info">
                    Showing @((_currentPage - 1) * PageSize + 1)–@(Math.Min(_currentPage * PageSize, _filtered.Count)) of @_filtered.Count
                </span>
                <div class="mti-page-btns">
                    <button class="mti-page-btn" disabled="@(_currentPage == 1)" @onclick="() => SetPage(_currentPage - 1)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                            <polyline points="15 18 9 12 15 6" />
                        </svg>
                    </button>
                    @for (var p = 1; p <= TotalPages; p++)
                    {
                        var pageNum = p;
                        <button class="mti-page-btn @(_currentPage == pageNum ? "mti-page-btn--active" : "")"
                                @onclick="() => SetPage(pageNum)">
                            @pageNum
                        </button>
                    }
                    <button class="mti-page-btn" disabled="@(_currentPage == TotalPages)" @onclick="() => SetPage(_currentPage + 1)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                            <polyline points="9 18 15 12 9 6" />
                        </svg>
                    </button>
                </div>
            </div>
        }
    }

</div>
