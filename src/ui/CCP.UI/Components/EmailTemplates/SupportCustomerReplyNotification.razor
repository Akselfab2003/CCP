@* SupportCustomerReplyNotification.razor - Sent to support team when customer replies *@
@using EmailService.Domain.Models

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Reply on Ticket #@Email.Id</title>
    <style>
            * { box-sizing: border-box; }
            body { margin: 0; padding: 0; background-color: #090c12; font-family: 'Instrument Sans', -apple-system, BlinkMacSystemFont, sans-serif; color: #e8ecf5; }
            .wrapper { width: 100%; background-color: #090c12; padding: 20px; }
            .container { max-width: 600px; margin: 0 auto; background-color: #141820; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3); border: 1px solid rgba(79, 148, 232, 0.15); }
            .header { background-color: #1b2030; padding: 28px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
            .header-text h1 { margin: 0 0 8px 0; color: #4f94e8; font-size: 20px; font-weight: 600; font-family: 'Syne', sans-serif; }
            .header-text p { margin: 0; color: #8b95b0; font-size: 13px; }
            .reply-alert {background: linear-gradient(135deg, #4f94e8, #93c5fd);border-left: 4px solid #4f94e8;padding: 16px 20px;margin: 20px 28px;border-radius: 8px;}
            .reply-alert .title {font-size: 14px;font-weight: 700;color: #4f94e8;margin: 0 0 4px 0;}
            .reply-alert .text { font-size: 13px; color: #e8ecf5; margin: 0; }
            .ticket-banner { background-color: rgba(27, 32, 48, 0.5); padding: 12px 28px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
            .ticket-id { font-size: 13px; color: #8b95b0; font-family: 'DM Mono', monospace; }
            .ticket-id span { color: #4f94e8; font-weight: 700; }
            .status-badge { font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 6px; text-transform: uppercase; background: rgba(79, 148, 232, 0.2); color: #4f94e8; border: 1px solid rgba(79, 148, 232, 0.3); }
            .body { padding: 28px; }
            .customer-row { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; padding: 12px; background-color: rgba(27, 32, 48, 0.5); border-radius: 8px; }
            .customer-avatar { width: 38px; height: 38px; border-radius: 50%; background: #4f94e8; color: #fff; font-size: 15px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
            .customer-info .name { font-size: 14px; font-weight: 700; color: #4f94e8; font-family: 'Syne', sans-serif; }
            .customer-info .email { font-size: 12px; color: #8b95b0; }
            .detail-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
            .detail-table td { padding: 10px 12px; font-size: 13px; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
            .detail-table td.label { color: #8b95b0; font-weight: 500; width: 140px; }
            .detail-table td.value { color: #e8ecf5; }
            .reply-box { background: #1b2030; border: 1px solid rgba(79, 148, 232, 0.3); border-left: 4px solid #4f94e8; border-radius: 8px; padding: 16px 20px; font-size: 14px; color: #e8ecf5; line-height: 1.6; margin-bottom: 20px; white-space: pre-wrap; }
            .reply-box .label { font-size: 11px; font-weight: 600; color: #4f94e8; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; display: block; }
            .history-toggle { font-size: 12px; color: #8b95b0; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid rgba(255, 255, 255, 0.08); font-family: 'DM Mono', monospace; }
            .history-toggle a { color: #4f94e8; text-decoration: none; }
            .cta { display: block; text-align: center; background-color: #4f94e8; color: #ffffff !important; text-decoration: none; padding: 14px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; margin-bottom: 16px; }
            .quick-actions { display: flex; gap: 10px; margin-bottom: 20px; }
            .quick-action { flex: 1; text-align: center; background-color: rgba(27, 32, 48, 0.5); color: #e8ecf5 !important; text-decoration: none; padding: 10px; border-radius: 8px; font-size: 13px; font-weight: 600; border: 1px solid rgba(255, 255, 255, 0.1); }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <div class="header-text">
                    <h1>Customer Reply Received</h1>
                    <p>@OrganizationName · Support Dashboard</p>
                </div>
            </div>

            <div class="reply-alert">
                <div class="title">New Message</div>
                <div class="text">The customer has replied to their ticket. Review and respond promptly.</div>
            </div>

            <div class="ticket-banner">
                <div class="ticket-id">Ticket: <span>#@Email.Id</span></div>
                <span class="status-badge">WAITING</span>
            </div>

            <div class="body">
                <div class="customer-row">
                    <div class="customer-avatar">@(CustomerName.Length > 0 ? CustomerName[0].ToString().ToUpper() : "C")</div>
                    <div class="customer-info">
                        <div class="name">@CustomerName</div>
                        <div class="email">@CustomerEmail</div>
                    </div>
                </div>

                <table class="detail-table">
                    <tr>
                        <td class="label">Ticket ID</td>
                        <td class="value" style="font-family: monospace; font-weight: 700;">#@Email.Id</td>
                    </tr>
                    <tr>
                        <td class="label">Subject</td>
                        <td class="value" style="font-weight: 600;">@Email.Subject</td>
                    </tr>
                    <tr>
                        <td class="label">Reply Time</td>
                        <td class="value">@Email.ReceivedAt.ToString("MMM dd, yyyy 'at' h:mm tt")</td>
                    </tr>
                    <tr>
                        <td class="label">Status</td>
                        <td class="value" style="color: #4f94e8; font-weight: 600;">@TicketStatusLabel</td>
                    </tr>
                </table>

                <div class="reply-box">
                    <span class="label">Customer's Message</span>
                    @Email.Body
                </div>

                <div class="history-toggle">
                    Conversation on ticket <strong>#@Email.Id</strong> · <a href="@ViewHistoryUrl">View full history</a>
                </div>

                <a href="@ReplyUrl" class="cta">Reply to Customer</a>

                <div class="quick-actions">
                    <a href="@ManagementUrl" class="quick-action">Manage Ticket</a>
                    <a href="@ViewHistoryUrl" class="quick-action">View History</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

@code {
    [Parameter, EditorRequired] public EmailService.Domain.Models.EmailReceived Email { get; set; } = default!;
    [Parameter] public string CustomerName { get; set; } = "Customer";
    [Parameter] public string CustomerEmail { get; set; } = "";
    [Parameter] public string OrganizationName { get; set; } = "Support";
    [Parameter] public string TicketStatus { get; set; } = "open";
    [Parameter] public string TicketStatusLabel { get; set; } = "Open";
    [Parameter] public string ReplyUrl { get; set; } = "#";
    [Parameter] public string ManagementUrl { get; set; } = "#";
    [Parameter] public string ViewHistoryUrl { get; set; } = "#";
}
