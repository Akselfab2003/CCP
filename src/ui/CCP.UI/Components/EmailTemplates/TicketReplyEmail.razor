@* TicketReplyEmail.razor - Sent to customer when support responds to a ticket *@
@using EmailService.Domain.Models

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Reply on Ticket #@Email.Id</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; padding: 0; background-color: #090c12; font-family: 'Instrument Sans', -apple-system, BlinkMacSystemFont, sans-serif; color: #e8ecf5; }
        .wrapper { width: 100%; background-color: #090c12; padding: 20px; }
        .container { max-width: 600px; margin: 0 auto; background-color: #141820; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3); border: 1px solid rgba(79, 148, 232, 0.15); }
        .header { background-color: #1b2030; padding: 28px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
        .header-text h1 { margin: 0 0 8px 0; color: #4f94e8; font-size: 20px; font-weight: 600; font-family: 'Syne', sans-serif; }
        .header-text p { margin: 0; color: #8b95b0; font-size: 13px; }
        .ticket-banner { background-color: rgba(27, 32, 48, 0.5); padding: 12px 28px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
        .ticket-id { font-size: 13px; color: #8b95b0; font-family: 'DM Mono', monospace; }
        .ticket-id span { color: #4f94e8; font-weight: 700; }
        .status-badge { font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 6px; text-transform: uppercase; border: 1px solid; }
        .status-open { background: rgba(79, 148, 232, 0.2); color: #4f94e8; border-color: rgba(79, 148, 232, 0.3); }
        .status-pending { background: rgba(251, 191, 36, 0.2); color: #fbbf24; border-color: rgba(251, 191, 36, 0.3); }
        .status-resolved { background: rgba(34, 197, 94, 0.2); color: #22c55e; border-color: rgba(34, 197, 94, 0.3); }
        .status-closed { background: rgba(139, 149, 176, 0.2); color: #8b95b0; border-color: rgba(139, 149, 176, 0.3); }
        .body { padding: 28px; }
        .greeting { font-size: 15px; color: #e8ecf5; margin: 0 0 20px 0; line-height: 1.6; }
        .agent-row { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; padding: 12px; background-color: rgba(27, 32, 48, 0.5); border-radius: 8px; }
        .agent-avatar { width: 38px; height: 38px; border-radius: 50%; background: #4f94e8; color: #fff; font-size: 15px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
        .agent-info .name { font-size: 14px; font-weight: 700; color: #4f94e8; font-family: 'Syne', sans-serif; }
        .agent-info .role { font-size: 12px; color: #8b95b0; }
        .reply-box { background: #1b2030; border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px; padding: 16px 20px; font-size: 14px; color: #e8ecf5; line-height: 1.6; margin-bottom: 20px; }
        .history-toggle { font-size: 12px; color: #8b95b0; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid rgba(255, 255, 255, 0.08); font-family: 'DM Mono', monospace; }
        .history-toggle a { color: #4f94e8; }
        .cta-row { display: flex; gap: 10px; margin-bottom: 20px; }
        .cta-primary { flex: 1; text-align: center; background-color: #4f94e8; color: #ffffff !important; text-decoration: none; padding: 12px; border-radius: 8px; font-size: 14px; font-weight: 600; }
        .cta-secondary { flex: 1; text-align: center; background-color: rgba(27, 32, 48, 0.5); color: #e8ecf5 !important; text-decoration: none; padding: 12px; border-radius: 8px; font-size: 14px; font-weight: 600; border: 1px solid rgba(255, 255, 255, 0.1); }
        .resolve-banner { background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.3); border-radius: 8px; padding: 12px 16px; font-size: 13px; color: #22c55e; text-align: center; }
        .resolve-banner a { color: #22c55e; }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <div class="header-text">
                    <h1>New Reply from Support</h1>
                    <p>@OrganizationName · Support Center</p>
                </div>
            </div>

            <div class="ticket-banner">
                <div class="ticket-id">Ticket: <span>#@Email.Id</span></div>
                <span class="status-badge status-@TicketStatus.ToLower()">@TicketStatusLabel</span>
            </div>

            <div class="body">
                <p class="greeting">
                    Hi <strong>@RecipientName</strong>,<br />
                    The support team has replied to your ticket.
                </p>

                <div class="agent-row">
                    <div class="agent-avatar">@(AgentName.Length > 0 ? AgentName[0].ToString().ToUpper() : "S")</div>
                    <div class="agent-info">
                        <div class="name">@AgentName</div>
                        <div class="role">@AgentRole · @OrganizationName Support</div>
                    </div>
                </div>

                <div class="reply-box">@Email.Body</div>

                <div class="history-toggle">
                    Reply to ticket <strong>#@Email.Id</strong> · @Email.ReceivedAt.ToString("MMM dd, yyyy 'at' h:mm tt")
                    &nbsp;·&nbsp; <a href="@ViewHistoryUrl">View full history</a>
                </div>

                <div class="cta-row">
                    <a href="@ReplyUrl" class="cta-primary">Reply to Ticket</a>
                    <a href="@PortalUrl" class="cta-secondary">View in Portal</a>
                </div>

                @if (TicketStatus == "resolved")
                {
                    <div class="resolve-banner">
                        This ticket has been marked as <strong>resolved</strong>.
                        Not satisfied with the response? <a href="@ReopenUrl">Reopen ticket</a>.
                    </div>
                }
            </div>
        </div>
    </div>
</body>
</html>

@code {
    [Parameter, EditorRequired] public EmailService.Domain.Models.EmailReceived Email { get; set; } = default!;
    [Parameter] public string RecipientName { get; set; } = "Customer";
    [Parameter] public string OrganizationName { get; set; } = "Support";
    [Parameter] public string AgentName { get; set; } = "Support Team";
    [Parameter] public string AgentRole { get; set; } = "Support Agent";
    [Parameter] public string TicketStatus { get; set; } = "open";
    [Parameter] public string TicketStatusLabel { get; set; } = "Open";
    [Parameter] public string ReplyUrl { get; set; } = "#";
    [Parameter] public string PortalUrl { get; set; } = "#";
    [Parameter] public string ViewHistoryUrl { get; set; } = "#";
    [Parameter] public string ReopenUrl { get; set; } = "#";
}
