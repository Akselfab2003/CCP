@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider

<!-- Floating button -->
<button id="chatToggle" class="@(IsOpen ? "open" : string.Empty)" @onclick="ToggleChat" aria-label="Åbn chat">
    <span id="chatBadge" class="@(BadgeVisible ? "visible" : string.Empty)"></span>
    <!-- Chat icon -->
    <svg class="icon-chat" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
    </svg>
    <!-- Close icon -->
    <svg class="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
    </svg>
</button>

<!-- Chat window -->
<div id="chatWindow" class="@(IsOpen ? "open" : string.Empty)" role="dialog" aria-label="Chat">
    <div class="chat-header">
        <div class="chat-header-avatar">B</div>
        <div class="chat-header-info">
            <div class="chat-header-name">Din Chatbot</div>
            <div class="chat-header-status">
                <span class="status-dot"></span> Online
            </div>
        </div>
    </div>

    <div class="chat-messages" id="chatMessages">
        @foreach (var m in Messages)
        {
            if (m.IsTyping)
            {
                <div class="typing-indicator">
                    <div class="typing-dot"></div>
                    <div class="typing-dot"></div>
                    <div class="typing-dot"></div>
                </div>
            }
            else
            {
                <div class="msg @m.Role">@m.Text<div class="msg-meta">@m.Time</div></div>
            }
        }
    </div>

    <form class="chat-input-area" id="chatForm" @onsubmit="OnSubmit" @onsubmit:preventDefault>
        <input id="chatInput" @bind="InputText" type="text" placeholder="Skriv en besked..." autocomplete="off" />
        <button type="submit" aria-label="Send">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="2" x2="11" y2="13" />
                <polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
        </button>
    </form>
</div>

@code {
    private record ChatMessage(string Text, string Role, string Time, bool IsTyping = false);
    private record ConversationTurn(string Role, string Content);
    private record ChatResponse(string Reply, bool TicketCreated, int? TicketId, string Intent);

    private HttpClient _chatClient = default!;

    private List<ChatMessage> Messages { get; } = new();
    private List<ConversationTurn> _history = new();
    private string InputText { get; set; } = string.Empty;
    private bool IsOpen { get; set; }
    private bool BadgeVisible { get; set; }

    private Guid _organizationId = Guid.Empty;
    private Guid? _customerId = null;
    private string _userName = string.Empty;
    private string _userEmail = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _chatClient = HttpClientFactory.CreateClient("ChatService");

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            _userName = user.FindFirst("name")?.Value
                     ?? user.FindFirst("preferred_username")?.Value
                     ?? string.Empty;

            _userEmail = user.FindFirst("email")?.Value
                      ?? string.Empty;

            var orgClaim = user.FindFirst("organization_id")?.Value;
            if (Guid.TryParse(orgClaim, out var orgId))
                _organizationId = orgId;

            var customerClaim = user.FindFirst("customer_id")?.Value;
            if (Guid.TryParse(customerClaim, out var customerId))
                _customerId = customerId;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(2000);
            BadgeVisible = true;
            StateHasChanged();
        }
    }

    private void ToggleChat()
    {
        IsOpen = !IsOpen;
        BadgeVisible = false;
    }

    private string GetTime() => DateTime.Now.ToString("HH:mm");

    private void AppendMsg(string text, string role)
    {
        Messages.Add(new ChatMessage(
            System.Net.WebUtility.HtmlEncode(text), role, GetTime()));
        InvokeAsync(StateHasChanged);
    }

    private ChatMessage ShowTyping()
    {
        var msg = new ChatMessage(string.Empty, "bot", string.Empty, IsTyping: true);
        Messages.Add(msg);
        InvokeAsync(StateHasChanged);
        return msg;
    }

    private async Task OnSubmit()
    {
        var text = InputText?.Trim();
        if (string.IsNullOrEmpty(text)) return;

        AppendMsg(text, "user");
        InputText = string.Empty;

        var typing = ShowTyping();

        var request = new
        {
            message = text,
            organizationId = _organizationId,
            customerId = _customerId,
            userName = _userName,
            userEmail = _userEmail,
            history = _history
        };

        try
        {
            var result = await _chatClient.PostAsJsonAsync("/api/chat/send", request);
            var response = await result.Content.ReadFromJsonAsync<ChatResponse>();

            Messages.Remove(typing);

            var reply = response?.Reply ?? "Noget gik galt. Prøv igen.";

            if (response?.TicketCreated == true)
                reply += $"\n\n✅ Ticket #{response.TicketId} er oprettet.";

            AppendMsg(reply, "bot");

            _history.Add(new ConversationTurn("user", text));
            _history.Add(new ConversationTurn("assistant", reply));
        }
        catch (Exception ex)
        {
            Messages.Remove(typing);
            AppendMsg($"FEJL: {ex.GetType().Name} — {ex.Message} | URL: {_chatClient.BaseAddress}", "bot");
        }
    }
}
