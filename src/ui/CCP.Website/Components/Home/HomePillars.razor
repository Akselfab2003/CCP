                <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
            </svg>
        </div>
        <h3 class="home-pillar-title">Built for Teams</h3>
        <p class="home-pillar-body">
            Internal notes, assignments, and handoffs keep your support staff aligned.
            Every ticket carries full context so nothing gets lost between shifts.
        </p>
        <a href="@References.Register" class="home-pillar-link">Start now →</a>
    </div>

    <div class="home-pillar">
        <div class="home-pillar-icon" style="--ic:#f59e0b;--ig:#d97706">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22">
                <path d="M18 20V10M12 20V4M6 20v-6" />
            </svg>
        </div>
        <h3 class="home-pillar-title">Real-Time Insights</h3>
        <p class="home-pillar-body">
            Dashboards that show resolution times, team workload, and customer satisfaction
