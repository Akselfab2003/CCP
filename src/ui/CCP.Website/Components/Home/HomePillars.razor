        <div class="home-pillar-icon" style="--ic:#6366f1;--ig:#8b5cf6">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" />
                <rect x="9" y="3" width="6" height="4" rx="1" />
                <path d="M9 12h6M9 16h4" />
            </svg>
        </div>
        <h3 class="home-pillar-title">Effortless Ticketing</h3>
        <p class="home-pillar-body">
            Submit a ticket in seconds and track every update in one place.
            No more lost emails or unanswered questions — just clear, structured support.
        </p>
        <a href="@References.Register" class="home-pillar-link">Start now →</a>
    </div>

    <div class="home-pillar">
        <div class="home-pillar-icon" style="--ic:#10b981;--ig:#059669">
