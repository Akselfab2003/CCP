@inject IWebsiteReferencesService References

<section class="home-cta">
    <div class="home-cta-glow" aria-hidden="true"></div>
    <h2 class="home-cta-title">Ready to streamline your support?</h2>
    <p class="home-cta-sub">
        Start for free — no credit card required. Set up in under 5 minutes.
    </p>
    <div class="home-cta-actions">
        <a href="@References.Register" class="home-btn home-btn-primary">
            Create Free Account
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
            </svg>
        </a>
        <a href="/" class="home-btn home-btn-ghost">Talk to Sales</a>
    </div>
</section>
