@* SupportCustomerReplyNotification.razor - Sent to support team when customer replies *@
@using CCP.Shared.ValueObjects
@using CustomerService.Sdk.Models
@using EmailService.Domain.Models
@using TicketService.Domain.Entities

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Reply on Ticket #@TicketId</title>
    <!--[if mso]>
    <style>
        table { border-collapse: collapse; }
        td { border-collapse: collapse; }
    </style>
    <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #090c12; font-family: Arial, sans-serif; color: #e8ecf5;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #090c12; padding: 20px 0;">
        <tr>
            <td align="center" style="padding: 20px;">
                <table width="100%" max-width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; background-color: #141820; border-radius: 12px; overflow: hidden;">
                    <!-- Header -->
                    <tr>
                        <td style="background-color: #1b2030; padding: 28px; border-bottom: 1px solid #2a3447;">
                            <h1 style="margin: 0 0 8px 0; color: #4f94e8; font-size: 20px; font-weight: 600; font-family: 'Syne', Arial, sans-serif;">Customer Reply Received</h1>
                            <p style="margin: 0; color: #8b95b0; font-size: 13px;">@OrganizationName · Support Dashboard</p>
                        </td>
                    </tr>

                    <!-- Reply Alert -->
                    <tr>
                        <td style="padding: 16px 28px; background-color: #1a3d5c; border-left: 4px solid #4f94e8;">
                            <p style="font-size: 14px; font-weight: 700; color: #93c5fd; margin: 0 0 4px 0;">New Message</p>
                            <p style="font-size: 13px; color: #e8ecf5; margin: 0;">The customer has replied to their ticket. Review and respond promptly.</p>
                        </td>
                    </tr>

                    <!-- Ticket Banner -->
                    <tr>
                        <td style="background-color: #1a2433; padding: 12px 28px; border-bottom: 1px solid #2a3447;">
                            <table width="100%" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="font-size: 13px; color: #8b95b0; font-family: ''Syne', Arial, sans-serif', monospace;">Ticket: <span style="color: #4f94e8; font-weight: 700;">#@TicketId</span></td>
                                    <td align="right" style="font-size: 11px;font-weight: 600;padding: 4px 12px;color: #4f94e8;border: 1px solid #4f94e8;border-radius: 6px;width: 30px;text-transform: uppercase;background-color: #1a3d5c; text-align: center;">@TicketStatus</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="padding: 28px;">
                            <!-- Customer Info Row -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #1a2433; padding: 12px; margin-bottom: 16px; border-radius: 6px;">
                                <tr>
                                    <td width="50" style="padding-right: 12px; vertical-align: top;">
                                        <div style="width: 38px; height: 38px; background-color: #4f94e8; color: #ffffff; font-size: 15px; font-weight: 700; display: flex; align-items: center; justify-content: center; border-radius: 50%; text-align: center; line-height: 38px;">@(Customer.Name.Length > 0 ? Customer.Name[0].ToString().ToUpper() : "C")</div>
                                    </td>
                                    <td style="vertical-align: top;">
                                        <p style="font-size: 14px; font-weight: 700; color: #4f94e8; margin: 0 0 2px 0; font-family: 'Syne', Arial, sans-serif;">@Customer.Name</p>
                                        <p style="font-size: 12px; color: #8b95b0; margin: 0;">@Customer.Email</p>
                                    </td>
                                </tr>
                            </table>

                            <!-- Details Table -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px; border-collapse: collapse;">
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #8b95b0; font-weight: 500; width: 40%;">Ticket ID</td>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #e8ecf5; font-family: 'Syne', Arial, sans-serif; font-weight: 700;">#@TicketId</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #8b95b0; font-weight: 500;">Subject</td>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #e8ecf5; font-weight: 600;">@Email.Subject</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #8b95b0; font-weight: 500;">Reply Time</td>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #e8ecf5;">@Email.ReceivedAt.ToString("MMM dd, yyyy 'at' h:mm tt")</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; color: #8b95b0; font-weight: 500;">Status</td>
                                    <td style="padding: 10px 12px; font-size: 13px; color: #4f94e8; font-weight: 600;">@TicketStatus</td>
                                </tr>
                            </table>

                            <!-- Customer Message -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #1b2030; border: 1px solid #4f94e8; border-left: 4px solid #4f94e8; padding: 16px 20px; margin-bottom: 20px;">
                                <tr>
                                    <td>
                                        <p style="font-size: 11px; font-weight: 600; color: #4f94e8; text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 12px 0;">Customer's Message</p>
                                        <p style="font-size: 14px; color: #e8ecf5; line-height: 1.6; margin: 0; white-space: pre-wrap;">@Email.Body</p>
                                    </td>
                                </tr>
                            </table>

                            <!-- Primary CTA Button -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td align="center">
                                        <a href="@ReplyUrl" style="display: inline-block; background-color: #4f94e8; color: #ffffff; text-decoration: none; padding: 14px 24px; border-radius: 6px; font-size: 14px; font-weight: 600;">Reply to Customer</a>
                                    </td>
                                </tr>
                            </table>

                            <!-- Quick Actions -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td style="padding: 0 6px; width: 50%;">
                                        <a href="@ManagementUrl" style="display: block; text-align: center; background-color: #1a2433; color: #e8ecf5; text-decoration: none; padding: 10px; border-radius: 6px; font-size: 13px; font-weight: 600; border: 1px solid #2a3447;">Manage Ticket</a>
                                    </td>
                                    <td style="padding: 0 6px; width: 50%;">
                                        <a href="@ViewHistoryUrl" style="display: block; text-align: center; background-color: #1a2433; color: #e8ecf5; text-decoration: none; padding: 10px; border-radius: 6px; font-size: 13px; font-weight: 600; border: 1px solid #2a3447;">View History</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>

@code {
    [Parameter, EditorRequired]
    public EmailReceived Email { get; set; } = default!;
    [Parameter, EditorRequired]
    public CustomerDTO Customer { get; set; } = default!;
    [Parameter]
    public int TicketId { get; set; } = default!;
    [Parameter]
    public TicketStatus TicketStatus { get; set; } = default!;
    [Parameter]
    public string OrganizationName { get; set; } = "Support";
    [Parameter]
    public string ReplyUrl { get; set; } = "#";
    [Parameter]
    public string ManagementUrl { get; set; } = "#";
    [Parameter]
    public string ViewHistoryUrl { get; set; } = "#";
}
