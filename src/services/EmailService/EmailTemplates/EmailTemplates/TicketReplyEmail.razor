<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Reply on Ticket #@Ticket.Id</title>
    <!--[if mso]>
    <style>
        table { border-collapse: collapse; }
        td { border-collapse: collapse; }
    </style>
    <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #090c12; font-family: Arial, sans-serif; color: #e8ecf5;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #090c12; padding: 20px 0;">
        <tr>
            <td align="center" style="padding: 20px;">
                <table width="100%" max-width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; background-color: #141820;">
                    <!-- Header -->
                    <tr>
                        <td style="background-color: #1b2030; padding: 28px; border-bottom: 1px solid #2a3447;">
                            <h1 style="margin: 0 0 8px 0; color: #4f94e8; font-size: 20px; font-weight: 600; font-family: 'Syne', Arial, sans-serif;">You Have a New Reply</h1>
                            <p style="margin: 0; color: #8b95b0; font-size: 13px;">@OrganizationName · Support Center</p>
                        </td>
                    </tr>

                    <!-- Ticket Banner -->
                    <tr>
                        <td style="background-color: #1a2433; padding: 12px 28px; border-bottom: 1px solid #2a3447;">
                            <table width="100%" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="font-size: 13px; color: #8b95b0; font-family: 'Syne', Arial, sans-serif;">Ticket: <span style="color: #4f94e8; font-weight: 700;">#@Email.Id</span></td>
                                    <td align="right" style="font-size: 11px;font-weight: 600;padding: 4px 12px;color: #4f94e8;border: 1px solid #4f94e8;border-radius: 6px;width: 30px;text-transform: uppercase;background-color: #1a3d5c;">Open</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="padding: 28px;">
                            <p style="font-size: 18px; font-weight: 600; color: #e8ecf5; text-align: center; margin: 0 0 8px 0; font-family: 'Syne', Arial, sans-serif;">Hello @RecipientName,</p>
                            <p style="font-size: 14px; color: #8b95b0; text-align: center; margin: 0 0 24px 0;">@AgentName (@AgentRole) has replied to your ticket.</p>

                            <!-- Agent Info -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #1a2433; border: 1px solid #2a3447; padding: 16px 20px; margin-bottom: 20px; border-radius: 8px;">
                                <tr>
                                    <td>
                                        <p style="font-size: 13px; font-weight: 600; color: #4f94e8; margin: 0 0 4px 0;">@AgentName</p>
                                        <p style="font-size: 12px; color: #8b95b0; margin: 0;">@AgentRole</p>
                                    </td>
                                </tr>
                            </table>

                            <!-- Ticket Details -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px; border-collapse: collapse;">
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #8b95b0; font-weight: 500; width: 40%;">Ticket ID</td>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #e8ecf5; font-family: 'Syne', Arial, sans-serif; font-weight: 700;">#@Email.Id</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #8b95b0; font-weight: 500;">Subject</td>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #e8ecf5;">@Email.Subject</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; color: #8b95b0; font-weight: 500;">Status</td>
                                    <td style="padding: 10px 12px; font-size: 13px; color: #1d4ed8; font-weight: 600;">@TicketStatusLabel</td>
                                </tr>
                            </table>

                            <!-- CTA Buttons -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td align="center" style="padding: 0 4px;">
                                        <a href="@ReplyUrl" style="display: inline-block; background-color: #4f94e8; color: #ffffff; text-decoration: none; padding: 12px 20px; border-radius: 6px; font-size: 13px; font-weight: 600;">Reply Now</a>
                                    </td>
                                    <td align="center" style="padding: 0 4px;">
                                        <a href="@ViewHistoryUrl" style="display: inline-block; background-color: #2a3f5c; color: #4f94e8; text-decoration: none; padding: 12px 20px; border-radius: 6px; font-size: 13px; font-weight: 600; border: 1px solid #4f94e8;">View History</a>
                                    </td>
                                </tr>
                            </table>

                            <!-- Support Note -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #1a3d5c; border-left: 3px solid #4f94e8; padding: 12px 16px;">
                                <tr>
                                    <td style="font-size: 13px; color: #e8ecf5; line-height: 1.6;">
                                        Click "Reply Now" to respond directly, or visit the portal to view your complete ticket history and add comments.
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>

@code {
    [Parameter, EditorRequired]
    public EmailService.Domain.Models.EmailReceived Email { get; set; } = default!;
    [Parameter, EditorRequired]
    public TicketService.Domain.Entities.Ticket Ticket { get; set; } = default!;
    [Parameter]
    public string OrganizationName { get; set; } = "Support";
    [Parameter]
    public string RecipientName { get; set; } = "Customer";
    [Parameter]
    public string AgentName { get; set; } = "";
    [Parameter]
    public string AgentRole { get; set; } = "";
    [Parameter]
    public string TicketStatus { get; set; } = "open";
    [Parameter]
    public string TicketStatusLabel { get; set; } = "Open";
    [Parameter]
    public string ReplyUrl { get; set; } = "#";
    [Parameter]
    public string PortalUrl { get; set; } = "#";
    [Parameter]
    public string ReopenUrl { get; set; } = "#";
    [Parameter]
    public string ViewHistoryUrl { get; set; } = "#";
}
