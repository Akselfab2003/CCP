@* SupportTicketNotification.razor - Sent to support team when customer creates a ticket *@
@using EmailService.Domain.Models

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Support Ticket #@Email.Id</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; padding: 0; background-color: #090c12; font-family: 'Instrument Sans', -apple-system, BlinkMacSystemFont, sans-serif; color: #e8ecf5; }
        .wrapper { width: 100%; background-color: #090c12; padding: 20px; }
        .container { max-width: 600px; margin: 0 auto; background-color: #141820; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3); border: 1px solid rgba(79, 148, 232, 0.15); }
        .header { background-color: #1b2030; padding: 28px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
        .header-text h1 { margin: 0 0 8px 0; color: #4f94e8; font-size: 20px; font-weight: 600; font-family: 'Syne', sans-serif; }
        .header-text p { margin: 0; color: #8b95b0; font-size: 13px; }
        .urgent-banner { background: linear-gradient(135deg, rgba(79, 148, 232, 0.2), rgba(59, 130, 246, 0.2)); border-left: 4px solid #4f94e8; padding: 16px 20px; margin: 20px 28px; border-radius: 8px; }
        .urgent-banner .title { font-size: 14px; font-weight: 700; color: #93c5fd; margin: 0 0 4px 0; }
        .urgent-banner .text { font-size: 13px; color: #e8ecf5; margin: 0; }
        .ticket-banner { background-color: rgba(27, 32, 48, 0.5); padding: 12px 28px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
        .ticket-id { font-size: 13px; color: #8b95b0; font-family: 'DM Mono', monospace; }
        .ticket-id span { color: #4f94e8; font-weight: 700; }
        .status-badge { font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 6px; text-transform: uppercase; background: rgba(79, 148, 232, 0.2); color: #4f94e8; border: 1px solid rgba(79, 148, 232, 0.3); }
        .body { padding: 28px; }
        .customer-info { background: rgba(27, 32, 48, 0.5); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px; padding: 16px 20px; margin-bottom: 20px; }
        .customer-info .label { font-size: 11px; font-weight: 600; color: #8b95b0; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
        .customer-info .value { font-size: 14px; color: #e8ecf5; font-weight: 600; }
        .detail-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        .detail-table td { padding: 10px 12px; font-size: 13px; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
        .detail-table td.label { color: #8b95b0; font-weight: 500; width: 140px; }
        .detail-table td.value { color: #e8ecf5; }
        .message-box { background: #1b2030; border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px; padding: 16px 20px; font-size: 14px; color: #e8ecf5; line-height: 1.6; margin-bottom: 20px; white-space: pre-wrap; }
        .message-box .label { font-size: 11px; font-weight: 600; color: #8b95b0; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; display: block; }
        .cta { display: block; text-align: center; background-color: #4f94e8; color: #ffffff !important; text-decoration: none; padding: 14px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; margin-bottom: 16px; }
        .footer-note { background: rgba(79, 148, 232, 0.08); border-left: 3px solid #4f94e8; border-radius: 6px; padding: 12px 16px; font-size: 12px; color: #8b95b0; line-height: 1.6; }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <div class="header-text">
                    <h1>New Support Ticket</h1>
                    <p>@OrganizationName · Support Dashboard</p>
                </div>
            </div>

            <div class="urgent-banner">
                <div class="title">Action Required</div>
                <div class="text">A customer has submitted a new support ticket. Response needed within @ExpectedResponseTime.</div>
            </div>

            <div class="ticket-banner">
                <div class="ticket-id">Ticket: <span>#@Email.Id</span></div>
                <span class="status-badge">NEW</span>
            </div>

            <div class="body">
                <div class="customer-info">
                    <div class="label">Customer</div>
                    <div class="value">@CustomerEmail</div>
                </div>

                <table class="detail-table">
                    <tr>
                        <td class="label">Ticket ID</td>
                        <td class="value" style="font-family: monospace; font-weight: 700;">#@Email.Id</td>
                    </tr>
                    <tr>
                        <td class="label">Subject</td>
                        <td class="value" style="font-weight: 600;">@Email.Subject</td>
                    </tr>
                    <tr>
                        <td class="label">Customer Email</td>
                        <td class="value">@CustomerEmail</td>
                    </tr>
                    <tr>
                        <td class="label">Created</td>
                        <td class="value">@Email.SentAt.ToString("MMM dd, yyyy 'at' h:mm tt")</td>
                    </tr>
                    <tr>
                        <td class="label">Expected Response</td>
                        <td class="value" style="color: #4f94e8; font-weight: 600;">@ExpectedResponseTime</td>
                    </tr>
                </table>

                <div class="message-box">
                    <span class="label">Customer Message</span>
                    @Email.Body
                </div>

                <a href="@ManagementUrl" class="cta">View & Respond to Ticket</a>

                <div class="footer-note">
                    <strong>Tip:</strong> Respond quickly to improve customer satisfaction. You can assign this ticket to a team member from the management dashboard.
                </div>
            </div>
        </div>
    </div>
</body>
</html>

@code {
    [Parameter, EditorRequired] public EmailService.Domain.Models.EmailSent Email { get; set; } = default!;
    [Parameter] public string CustomerEmail { get; set; } = "";
    [Parameter] public string OrganizationName { get; set; } = "Support";
    [Parameter] public string ExpectedResponseTime { get; set; } = "24 hours";
    [Parameter] public string ManagementUrl { get; set; } = "#";
}
