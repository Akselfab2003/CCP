@* SupportTicketNotification.razor - Sent to support team when customer creates a ticket *@
@using EmailService.Domain.Models

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Support Ticket #@Email.Id</title>
    <!--[if mso]>
    <style>
        table { border-collapse: collapse; }
        td { border-collapse: collapse; }
    </style>
    <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #090c12; font-family: Arial, sans-serif; color: #e8ecf5;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #090c12; padding: 20px 0;">
        <tr>
            <td align="center" style="padding: 20px;">
                <table width="100%" max-width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; background-color: #141820;">
                    <!-- Header -->
                    <tr>
                        <td style="background-color: #1b2030; padding: 28px; border-bottom: 1px solid #2a3447;">
                            <h1 style="margin: 0 0 8px 0; color: #4f94e8; font-size: 20px; font-weight: 600; font-family: 'Syne', Arial, sans-serif;">New Support Ticket</h1>
                            <p style="margin: 0; color: #8b95b0; font-size: 13px;">@OrganizationName · Support Dashboard</p>
                        </td>
                    </tr>

                    <!-- Urgent Banner -->
                    <tr>
                        <td style="padding: 16px 28px; background-color: #1a3d5c; border-left: 4px solid #4f94e8; margin: 20px 0;">
                            <p style="font-size: 14px; font-weight: 700; color: #93c5fd; margin: 0 0 4px 0;">Action Required</p>
                            <p style="font-size: 13px; color: #e8ecf5; margin: 0;">A customer has submitted a new support ticket. Response needed within @ExpectedResponseTime.</p>
                        </td>
                    </tr>

                    <!-- Ticket Banner -->
                    <tr>
                        <td style="background-color: #1a2433; padding: 12px 28px; border-bottom: 1px solid #2a3447;">
                            <table width="100%" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="font-size: 13px; color: #8b95b0; font-family: ''Syne', Arial, sans-serif', monospace;">Ticket: <span style="color: #4f94e8; font-weight: 700;">#@Email.Id</span></td>
                                    <td align="right" style="font-size: 11px;font-weight: 600;padding: 4px 12px;color: #4f94e8;border: 1px solid #4f94e8;border-radius: 6px;width: 30px;text-transform: uppercase;background-color: #1a3d5c;">Open</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="padding: 28px;">
                            <!-- Customer Info Box -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #1a2433; border: 1px solid #2a3447; padding: 16px 20px; margin-bottom: 20px;">
                                <tr>
                                    <td>
                                        <p style="font-size: 11px; font-weight: 600; color: #8b95b0; text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 8px 0;">Customer</p>
                                        <p style="font-size: 14px; color: #e8ecf5; font-weight: 600; margin: 0;">@CustomerEmail</p>
                                    </td>
                                </tr>
                            </table>

                            <!-- Details Table -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px; border-collapse: collapse;">
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #8b95b0; font-weight: 500; width: 40%;">Ticket ID</td>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #e8ecf5; font-family: 'Syne', Arial, sans-serif; font-weight: 700;">#@Email.Id</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #8b95b0; font-weight: 500;">Subject</td>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #e8ecf5; font-weight: 600;">@Email.Subject</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #8b95b0; font-weight: 500;">Customer Email</td>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #e8ecf5;">@CustomerEmail</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #8b95b0; font-weight: 500;">Created</td>
                                    <td style="padding: 10px 12px; font-size: 13px; border-bottom: 1px solid #2a3447; color: #e8ecf5;">@Email.SentAt.ToString("MMM dd, yyyy 'at' h:mm tt")</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 12px; font-size: 13px; color: #8b95b0; font-weight: 500;">Expected Response</td>
                                    <td style="padding: 10px 12px; font-size: 13px; color: #4f94e8; font-weight: 600;">@ExpectedResponseTime</td>
                                </tr>
                            </table>

                            <!-- Customer Message -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #1b2030; border: 1px solid #2a3447; padding: 16px 20px; margin-bottom: 20px;">
                                <tr>
                                    <td>
                                        <p style="font-size: 11px; font-weight: 600; color: #8b95b0; text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 12px 0;">Customer Message</p>
                                        <p style="font-size: 14px; color: #e8ecf5; line-height: 1.6; margin: 0; white-space: pre-wrap;">@Email.Body</p>
                                    </td>
                                </tr>
                            </table>

                            <!-- CTA Button -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td align="center">
                                        <a href="@ManagementUrl" style="display: inline-block; background-color: #4f94e8; color: #ffffff; text-decoration: none; padding: 14px 24px; border-radius: 6px; font-size: 14px; font-weight: 600;">View & Respond to Ticket</a>
                                    </td>
                                </tr>
                            </table>

                            <!-- Footer Note -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #1a3d5c; border-left: 3px solid #4f94e8; padding: 12px 16px;">
                                <tr>
                                    <td style="font-size: 12px; color: #8b95b0; line-height: 1.6;">
                                        <strong style="color: #e8ecf5;">Tip:</strong> Respond quickly to improve customer satisfaction. You can assign this ticket to a team member from the management dashboard.
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>

@code {
    [Parameter, EditorRequired] public EmailService.Domain.Models.EmailSent Email { get; set; } = default!;
    [Parameter] public string CustomerEmail { get; set; } = "";
    [Parameter] public string OrganizationName { get; set; } = "Support";
    [Parameter] public string ExpectedResponseTime { get; set; } = "24 hours";
    [Parameter] public string ManagementUrl { get; set; } = "#";
}
