@* TicketStatusEmail.razor - Sent when a ticket's status changes (e.g. resolved, closed, pending) *@
@using EmailService.Domain.Models

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticket #@Email.Id – Status Updated</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; padding: 0; background-color: #090c12; font-family: 'Instrument Sans', -apple-system, BlinkMacSystemFont, sans-serif; color: #e8ecf5; }
        .wrapper { width: 100%; background-color: #090c12; padding: 20px; }
        .container { max-width: 600px; margin: 0 auto; background-color: #141820; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3); border: 1px solid rgba(79, 148, 232, 0.15); }
        .header { background-color: #1b2030; padding: 28px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
        .header-text h1 { margin: 0 0 8px 0; color: #4f94e8; font-size: 20px; font-weight: 600; font-family: 'Syne', sans-serif; }
        .header-text p { margin: 0; color: #8b95b0; font-size: 13px; }
        .ticket-banner { background-color: rgba(27, 32, 48, 0.5); padding: 12px 28px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
        .ticket-id { font-size: 13px; color: #8b95b0; font-family: 'DM Mono', monospace; }
        .ticket-id span { color: #4f94e8; font-weight: 700; }
        .status-badge { font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 6px; text-transform: uppercase; border: 1px solid; }
        .status-open { background: rgba(79, 148, 232, 0.2); color: #4f94e8; border-color: rgba(79, 148, 232, 0.3); }
        .status-pending { background: rgba(251, 191, 36, 0.2); color: #fbbf24; border-color: rgba(251, 191, 36, 0.3); }
        .status-resolved { background: rgba(34, 197, 94, 0.2); color: #22c55e; border-color: rgba(34, 197, 94, 0.3); }
        .status-closed { background: rgba(139, 149, 176, 0.2); color: #8b95b0; border-color: rgba(139, 149, 176, 0.3); }
        .body { padding: 28px; }
        .status-hero { text-align: center; padding: 8px 0 24px 0; }
        .status-hero h2 { margin: 0 0 8px 0; font-size: 18px; color: #e8ecf5; font-family: 'Syne', sans-serif; font-weight: 600; }
        .status-hero p { margin: 0; font-size: 14px; color: #8b95b0; }
        .change-row { display: flex; align-items: center; justify-content: center; gap: 12px; margin: 0 0 24px 0; }
        .old-status { font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 6px; text-transform: uppercase; background: rgba(139, 149, 176, 0.2); color: #8b95b0; border: 1px solid rgba(139, 149, 176, 0.3); }
        .arrow { font-size: 16px; color: #8b95b0; }
        .new-status-open { background: rgba(79, 148, 232, 0.2); color: #4f94e8; border-color: rgba(79, 148, 232, 0.3); }
        .new-status-pending { background: rgba(251, 191, 36, 0.2); color: #fbbf24; border-color: rgba(251, 191, 36, 0.3); }
        .new-status-resolved { background: rgba(34, 197, 94, 0.2); color: #22c55e; border-color: rgba(34, 197, 94, 0.3); }
        .new-status-closed { background: rgba(139, 149, 176, 0.2); color: #8b95b0; border-color: rgba(139, 149, 176, 0.3); }
        .detail-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        .detail-table td { padding: 10px 12px; font-size: 13px; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
        .detail-table td.label { color: #8b95b0; font-weight: 500; }
        .detail-table td.value { color: #e8ecf5; }
        .note-box { background: #1b2030; border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px; padding: 16px 20px; font-size: 14px; color: #e8ecf5; line-height: 1.6; margin-bottom: 20px; }
        .note-label { font-size: 11px; color: #8b95b0; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
        .cta { display: block; text-align: center; background-color: #4f94e8; color: #ffffff !important; text-decoration: none; padding: 12px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; margin-bottom: 16px; }
        .reopen-link { text-align: center; font-size: 13px; color: #8b95b0; }
        .reopen-link a { color: #4f94e8; }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <div class="header-text">
                    <h1>Status Updated</h1>
                    <p>@OrganizationName · Support Center</p>
                </div>
            </div>

            <div class="ticket-banner">
                <div class="ticket-id">Ticket: <span>#@Email.Id</span></div>
                <span class="status-badge status-@NewStatus.ToLower()">@NewStatusLabel</span>
            </div>

            <div class="body">
                <div class="status-hero">
                    <h2>@StatusHeadline</h2>
                    <p>Ticket #@Email.Id · @Email.Subject</p>
                </div>

                <div class="change-row">
                    <span class="old-status">@OldStatusLabel</span>
                    <span class="arrow">→</span>
                    <span class="old-status new-status-@NewStatus.ToLower()">@NewStatusLabel</span>
                </div>

                <table class="detail-table">
                    <tr>
                        <td class="label">Ticket</td>
                        <td class="value" style="font-family: monospace; font-weight: 700;">#@Email.Id</td>
                    </tr>
                    <tr>
                        <td class="label">Subject</td>
                        <td class="value">@Email.Subject</td>
                    </tr>
                    <tr>
                        <td class="label">Updated</td>
                        <td class="value">@Email.SentAt.ToString("MMM dd, yyyy 'at' h:mm tt")</td>
                    </tr>
                    @if (!string.IsNullOrEmpty(UpdatedByAgent))
                    {
                        <tr>
                            <td class="label">Updated by</td>
                            <td class="value">@UpdatedByAgent</td>
                        </tr>
                    }
                </table>

                @if (!string.IsNullOrWhiteSpace(AgentNote))
                {
                    <div class="note-box">
                        <strong class="note-label">Note from support</strong>
                        @AgentNote
                    </div>
                }

                <a href="@PortalUrl" class="cta">View Ticket in Portal</a>

                @if (NewStatus == "resolved" || NewStatus == "closed")
                {
                    <div class="reopen-link">
                        Not satisfied? <a href="@ReopenUrl">Reopen this ticket</a>
                    </div>
                }
            </div>
        </div>
    </div>
</body>
</html>

@code {
    [Parameter, EditorRequired] public EmailService.Domain.Models.EmailSent Email { get; set; } = default!;
    [Parameter] public string OrganizationName { get; set; } = "Support";
    [Parameter] public string NewStatus { get; set; } = "resolved";
    [Parameter] public string NewStatusLabel { get; set; } = "Resolved";
    [Parameter] public string OldStatusLabel { get; set; } = "Open";
    [Parameter] public string UpdatedByAgent { get; set; } = "";
    [Parameter] public string AgentNote { get; set; } = "";
    [Parameter] public string PortalUrl { get; set; } = "#";
    [Parameter] public string ReopenUrl { get; set; } = "#";

    private string StatusHeadline => NewStatus switch {
        "resolved" => "Your ticket has been resolved",
        "closed"   => "Ticket has been closed",
        "pending"  => "Awaiting your response",
        _          => "Status has been updated"
    };
}
