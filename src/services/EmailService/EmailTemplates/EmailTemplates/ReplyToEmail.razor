@using EmailService.Domain.Models
@using TicketService.Domain.Entities

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticket Reply – #@Ticket.Id</title>
    <!--[if mso]>
    <style>
        table { border-collapse: collapse; }
        td { border-collapse: collapse; }
    </style>
    <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #f3f5f7; font-family: Arial, sans-serif; color: #1f2937;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f3f5f7; padding: 24px 12px;">
        <tr>
            <td align="center">
                <table width="100%" cellpadding="0" cellspacing="0" style="max-width: 640px; background-color: #ffffff; border: 1px solid #e5e7eb; border-collapse: collapse;">
                    <tr>
                        <td style="padding: 24px 28px; border-bottom: 1px solid #e5e7eb;">
                            <p style="margin: 0; font-size: 12px; letter-spacing: 0.4px; text-transform: uppercase; color: #6b7280;">@OrganizationName - Support</p>
                        </td>
                    </tr>
                    @if (!string.IsNullOrWhiteSpace(Email.Body))
                    {
                        <tr>
                            <td style="padding: 16px;">
                                <p style="margin: 0; font-size: 14px; line-height: 1.6; color: #111827;">@Email.Body</p>
                            </td>
                        </tr>
                    }
                </table>
            </td>
        </tr>
    </table>
</body>
</html>

@code {
    [Parameter, EditorRequired]
    public EmailReceived Email { get; set; } = default!;

    [Parameter, EditorRequired]
    public Ticket Ticket { get; set; } = default!;

    [Parameter]
    public string OrganizationName { get; set; } = "Support";
}
